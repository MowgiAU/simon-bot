<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup/restore exclusion rules.
    Exclude all app data from cloud and device-to-device backup.
    Session tokens and user data must not leave the device via backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
