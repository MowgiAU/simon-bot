# ═══════════════════════════════════════════════════════════════════════
# Fuji Studio — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════

# ── Discord Bot ──────────────────────────────────────────────────────
DISCORD_TOKEN=your_production_bot_token
DISCORD_CLIENT_ID=your_production_client_id
DISCORD_CLIENT_SECRET=your_production_client_secret
DISCORD_REDIRECT_URI=https://fujistud.io/api/auth/discord/callback
DISCORD_STORAGE_GUILD_ID=your_storage_guild_id
PROJECT_STORAGE_GUILD_ID=your_project_storage_guild_id
FUJI_STORAGE_GUILD_ID=your_fuji_storage_guild_id

# ── Database (DigitalOcean Managed PostgreSQL) ───────────────────────
# Connection pooler URL (port 25061, sslmode=require)
DATABASE_URL=postgresql://user:password@db-host:25061/defaultdb?sslmode=require&pgbouncer=true
# Direct connection URL (port 25060, for migrations)
DIRECT_DATABASE_URL=postgresql://user:password@db-host:25060/defaultdb?sslmode=require

# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0
API_URL=https://fujistud.io
DASHBOARD_URL=https://fujistud.io
DASHBOARD_ORIGIN=https://fujistud.io
SESSION_SECRET=generate_a_strong_random_secret_here
GUILD_ID=955342751669551165
LOG_LEVEL=info

# ── External Services ────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
RESEND_API_KEY=your_resend_api_key

# ── Cloudflare R2 Storage ────────────────────────────────────────────
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=fujistudiosamples
CDN_URL=https://cdn.fujistud.io

# ── Feature Flags ────────────────────────────────────────────────────
INVITE_ONLY=true
# Set to false to open the frontend to all users

# ── Misc ─────────────────────────────────────────────────────────────
BOT_PREFIX=!
FUJI_LIST_PATH="/root/simon-bot/samplecategories.txt"
PROJECT_ZIP_MAX_SIZE_MB=100
