{
  "name": "simon-bot",
  "version": "1.0.0",
  "description": "Modular Discord bot for FL Studio music producer community",
  "main": "dist/bot/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bot/start.ts",
    "build": "npx prisma generate && tsc",
    "start": "tsx src/bot/start.ts",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "api:dev": "tsx watch src/api/index.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "migrate": "prisma migrate dev",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "bot",
    "plugin",
    "modular"
  ],
  "author": "Simon Bot Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.18.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@mui/material": "^7.3.8",
    "@prisma/client": "^5.7.0",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.5",
    "clamscan": "^2.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "libsodium-wrappers": "^0.8.2",
    "lucide-react": "^0.563.0",
    "mailparser": "^3.9.3",
    "multer": "^2.1.0",
    "music-metadata": "^7.14.0",
    "openai": "^6.17.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.2.3",
    "prism-media": "^1.3.5",
    "resend": "^6.9.1",
    "sharp": "^0.34.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/clamscan": "^2.4.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/form-data": "^2.2.1",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
