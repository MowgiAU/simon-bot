// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- User Accounts (Native auth with optional Discord linking) ---
model User {
  id                       String    @id @default(cuid())
  discordId                String?   @unique
  email                    String?   @unique
  emailVerified            DateTime?
  emailVerificationToken   String?   @unique
  emailVerificationExpiry  DateTime?
  username                 String    @unique
  displayName              String?
  avatar                   String?
  passwordHash             String?
  lastLoginAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // 2FA (TOTP)
  totpSecret               String?   // Encrypted TOTP secret
  totpEnabled              Boolean   @default(false)
  totpBackupCodes          String[]  @default([]) // Hashed backup codes

  // Account recovery
  passwordResetToken       String?   @unique
  passwordResetExpiry      DateTime?

  // Pending email change (verified before applying)
  pendingEmail             String?
  pendingEmailToken        String?   @unique
  pendingEmailExpiry       DateTime?

  @@map("users")
}

// Guild configuration
model Guild {
  id        String   @id
  name      String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members            Member[]
  wordGroups         WordGroup[]
  filterSettings     FilterSettings?
  channelStats       ChannelStats[]
  serverStats        ServerStats[]
  pluginSettings     PluginSettings[]
  dashboardAccess    DashboardAccess?
  actionLogs         ActionLog[]
  userNotes          UserNote[]

  // Channel Rules
  channelRuleSettings ChannelRuleSettings?
  channelRules        ChannelRule[]
  pendingReviews      PendingReview[]

  moderationSettings ModerationSettings?
  welcomeGateSettings WelcomeGateSettings?

  economyAccounts    EconomyAccount[]
  economySettings    EconomySettings?
  economyItems       EconomyItem[]
  economyInventory   EconomyInventory[]
  economyTrans       EconomyTransaction[]

  // Feedback Plugin
  feedbackProfiles   FeedbackProfile[]
  feedbackPosts      FeedbackPost[]
  feedbackSettings   FeedbackSettings?

  // Ticket System
  ticketSettings     TicketSettings?
  tickets            Ticket[]

  // Beat Battle
  beatBattles          BeatBattle[]
  battleSponsors       BattleSponsor[]
  beatBattleSettings   BeatBattleSettings?

  // Voice Monitor
  voiceMonitorSettings VoiceMonitorSettings?
  voiceSessions        VoiceSession[]
  voiceReports         VoiceReport[]

  // Leveling
  levelingSettings     LevelingSettings?

  // Anti-Piracy
  antiPiracySettings   AntiPiracySettings?

  // Radio
  radioSettings        RadioSettings?

  // Studio Guide
  studioGuideSettings  StudioGuideSettings?

  @@map("guilds")
}

// Bot Identity Settings
model BotSettings {
  botId       String @id
  status      String @default("online")
  activityType String @default("PLAYING")
  activityText String?
  username    String?
  avatarUrl   String?
  updatedAt   DateTime @updatedAt

  @@map("bot_settings")
}

// Moderation Settings
model ModerationSettings {
  id             String   @id @default(cuid())
  guildId        String   @unique
  logChannelId   String?  // Channel to send nice embeds to
  dmUponAction   Boolean  @default(true) // DM user when kicked/banned?

  // Custom Messages
  kickMessage    String?  // e.g. "You were kicked from {server} for: {reason}"
  banMessage     String?
  timeoutMessage String?
  
  permissions    ModerationPermission[]
  
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@map("moderation_settings")
}

model ModerationPermission {
  id             String   @id @default(cuid())
  settingsId     String
  roleId         String   // Discord Role ID
  
  // Permissions
  canWarn        Boolean @default(false)
  canKick        Boolean @default(false)
  canBan         Boolean @default(false)
  canTimeout     Boolean @default(false)
  canPurge       Boolean @default(false)
  canViewLogs    Boolean @default(false)
  
  settings       ModerationSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  
  @@unique([settingsId, roleId])
  @@map("moderation_permissions")
}

// ---------------------------------------------------------
// Existing Models Below
// ---------------------------------------------------------

// Action Logs for Auditing
model ActionLog {
  id         String   @id @default(cuid())
  guildId    String
  pluginId   String   // e.g., 'word-filter', 'moderation'
  action     String   // e.g., 'message_deleted', 'user_banned'
  executorId String?  // ID of user/bot who performed action
  targetId   String?  // ID of user/message/channel affected
  details    Json?    // Context specific data
  searchableText String @default("") // Quick search vector (names, ids, content)
  createdAt  DateTime @default(now())

  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  comments   LogComment[]

  @@index([guildId, createdAt])
  @@map("action_logs")
}

model LogComment {
  id        String    @id @default(cuid())
  logId     String
  userId    String    // Admin who made the comment
  content   String
  createdAt DateTime  @default(now())

  log       ActionLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@index([logId])
  @@map("log_comments")
}

model UserNote {
  id        String    @id @default(cuid())
  guildId   String
  userId    String    // The user being noted on
  adminId   String    // Admin who made the note
  content   String
  createdAt DateTime  @default(now())

  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@map("user_notes")
}

model ScheduledTask {
  id        String   @id @default(cuid())
  guildId   String
  type      String   // e.g. 'unban'
  targetId  String
  executeAt DateTime
  data      Json?    // e.g. { "reason": "Time Served" }
  createdAt DateTime @default(now())

  @@index([executeAt])
  @@map("scheduled_tasks")
}

// Guild members - leveling, currency, etc.
model Member {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  
  // Leveling system
  level     Int      @default(0)
  xp        Int      @default(0)
  totalXp   Int      @default(0)
  
  // Leveling tracking
  voiceMinutes     Int      @default(0)
  messagesCount    Int      @default(0)
  reactionsGiven   Int      @default(0)
  reactionsReceived Int     @default(0)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastMessageAt    DateTime?
  lastDailyAt      DateTime?
  earnedRoles      String[] @default([])
  
  // Currency system
  balance   Int      @default(0)
  
  // Tracking
  lastActiveAt DateTime @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  feedbackProfile    FeedbackProfile?

  @@unique([guildId, userId])
  @@index([guildId, totalXp])
  @@index([guildId, voiceMinutes])
  @@map("members")
}

// Word Filter Plugin
model FilterSettings {
  id           String   @id @default(cuid())
  guildId      String   @unique
  
  // Global settings
  enabled      Boolean  @default(true)
  repostEnabled Boolean @default(true)
  
  // Excluded channels and roles (JSON arrays of IDs)
  excludedChannels String[] @default([])
  excludedRoles    String[] @default([])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  guild        Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  wordGroups   WordGroup[]

  @@map("filter_settings")
}

model WordGroup {
  id           String   @id @default(cuid())
  guildId      String
  name         String   // e.g., "Slurs", "Spam"
  
  // Replacement (word or emoji)
  replacementText String?
  replacementEmoji String?
  useEmoji     Boolean  @default(false)
  enabled      Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  guild        Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  settings     FilterSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade, map: "word_groups_settings_fkey")
  words        FilterWord[]

  @@unique([guildId, name])
  @@map("word_groups")
}

model FilterWord {
  id        String   @id @default(cuid())
  groupId   String
  word      String
  
  createdAt DateTime @default(now())

  // Relations
  group     WordGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, word])
  @@map("filter_words")
}

// Statistics Models

model ChannelStats {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  channelName String
  date        DateTime @db.Date
  messages    Int      @default(0)
  
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId, date])
  @@map("channel_stats")
}

model ServerStats {
  id            String   @id @default(cuid())
  guildId       String
  date          DateTime @db.Date
  memberCount   Int      @default(0)
  messageCount  Int      @default(0)
  voiceMinutes  Int      @default(0)
  newBans       Int      @default(0)
  
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@unique([guildId, date])
  @@map("server_stats")
}

// Plugin Management
model PluginSettings {
  id             String   @id @default(cuid())
  guildId        String
  pluginId       String
  
  enabled        Boolean  @default(true)
  allowedRoles   String[] @default([]) // Roles that can configure this plugin
  
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@unique([guildId, pluginId])
  @@map("plugin_settings")
}

model DashboardAccess {
  id             String   @id @default(cuid())
  guildId        String   @unique
  allowedRoles   String[] @default([]) // Roles that can login to dashboard
  
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@map("dashboard_access")
}

// Internal Messaging & Notifications
model DashboardMessage {
  id          String   @id @default(cuid())
  guildId     String
  senderId    String   // Discord User ID
  recipientId String?  // Optional: Discord User ID (null means global/broadcast)
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  @@index([guildId, recipientId])
  @@index([guildId, senderId])
  @@map("dashboard_messages")
}

model Notification {
  id          String   @id @default(cuid())
  guildId     String
  userId      String   // Recipient Discord User ID
  type        String   // 'mention', 'message', 'system'
  title       String
  message     String
  link        String?  // Optional path to redirect to (e.g., '/logs?id=123')
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  @@index([guildId, userId, isRead])
  @@map("dashboard_notifications")
}

// Economy System
model EconomyAccount {
  id             String   @id @default(cuid())
  guildId        String
  userId         String
  balance        Int      @default(0)
  totalEarned    Int      @default(0) // Lifetime earnings
  lastDaily      DateTime?
  lastWeekly     DateTime?
  
  // Relations
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("economy_accounts")
}

model EconomySettings {
  id             String   @id @default(cuid())
  guildId        String   @unique
  
  // Configuration
  currencyName   String   @default("Coins")
  currencyEmoji  String   @default("🪙")
  
  // Earning
  messageReward  Int      @default(5)
  messageCooldown Int     @default(60) // Seconds between message rewards
  minMessageLength Int    @default(10)
  
  // Features
  autoNickname   Boolean  @default(false)
  allowTipping   Boolean  @default(true)
  
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("economy_settings")
}

model EconomyItem {
  id             String   @id @default(cuid())
  guildId        String
  
  name           String
  description    String?
  price          Int
  type           String   // ROLE, EXTERNAL, ITEM
  category       String   @default("General")
  
  // Metadata for types (e.g., Role ID for ROLE type)
  metadata       Json?    
  
  // Stock control
  stock          Int?     // Null = infinite
  maxPerUser     Int?
  
  createdAt      DateTime @default(now())

  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@unique([guildId, name]) // Unique names per guild
  @@map("economy_items")
}

model EconomyInventory {
  id             String   @id @default(cuid())
  guildId        String
  userId         String
  itemId         String
  quantity       Int      @default(1)
  
  acquiredAt     DateTime @default(now())
  
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // No strict relation to item to allow keeping items if they are deleted from shop (legacy support)
  // But for now, let's keep it simple. If we delete from shop, maybe we want to keep it in inventory?
  // Let's create a relation but set OnDelete SetNull? Or just rely on ID string.
  // Using ID string is safer for "archived" items.

  @@unique([guildId, userId, itemId])
  @@map("economy_inventory")
}

model EconomyTransaction {
  id             String   @id @default(cuid())
  guildId        String
  
  fromUserId     String?  // Null if system
  toUserId       String?  // Null if burning/system
  amount         Int
  type           String   // MESSAGE, SHOP, TIP, DAILY, ADMIN
  reason         String?
  
  createdAt      DateTime @default(now())

  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@index([guildId, fromUserId])
  @@index([guildId, toUserId])
  @@map("economy_transactions")
}

// Feedback / AI Production System (New Plugin)
model FeedbackProfile {
  id         String   @id @default(cuid())
  guildId    String
  userId     String
  
  genre      String?
  daw        String?
  experience String?
  
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // We can treat Member as optional relation or just store IDs if Member not guaranteed
  // But strictly Member should exist.
  member     Member   @relation(fields: [guildId, userId], references: [guildId, userId], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("feedback_profiles")
}

model FeedbackPost {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  threadId    String?
  userId      String
  messageId   String   @unique
  content     String
  
  hasAudio    Boolean  @default(false)
  audioUrl    String?
  referenceUrl String? // URL of the thread starter audio (for comparison)
  
  aiScore     Int?
  aiState     String   @default("PENDING") // PENDING, APPROVED, DENIED, UNSURE, REJECTED
  aiReason    String?
  
  postType    String   @default("COMMENT") // COMMENT, FEEDBACK
  
  moderationMessageId String? // ID of the message in the clean/mod-log channel
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, aiState])
  @@map("feedback_posts")
}

model FeedbackSettings {
  id              String   @id @default(cuid())
  guildId         String   @unique
  
  enabled         Boolean  @default(false)
  forumChannelId  String?
  reviewChannelId String?
  modLogChannelId String?
  
  currencyReward  Int      @default(1)
  threadCost      Int      @default(5)
  
  aiModel         String   @default("gpt-4o-mini")
  
  guild           Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("feedback_settings")
}


// Welcome Gate System
model WelcomeGateSettings {
  id               String   @id @default(cuid())
  guildId          String   @unique
  enabled          Boolean  @default(false)
  
  welcomeChannelId String?
  unverifiedRoleId String?
  verifiedRoleId   String?
  
  questions        String[] // Array of questions
  modalTitle       String   @default("Server Verification")
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt


  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("welcome_gate_settings")
}

// Ticket System
model TicketSettings {
  id             String @id @default(cuid())
  guildId        String @unique
  ticketCategoryId String?
  staffRoleIds   String[]
  transcriptChannelId String?
  ticketMessage  String? @default("Click the button below to open a ticket")
  
  guild          Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  @@map("ticket_settings")
}

model Ticket {
  id        String   @id @default(cuid())
  channelId String   @unique
  guildId   String
  ownerId   String
  ownerName String?   // Added to track the name of the person who opened the ticket
  status    String   @default("open")
  priority  String   @default("low") // low, medium, high
  createdAt DateTime @default(now())
  closedAt  DateTime?

  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  authorName String
  content   String
  attachments String? // Stored as JSON string or comma-separated
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  @@map("ticket_messages")
}

// Channel Rules & Moderation (Gatekeeper)
model ChannelRuleSettings {
  id               String   @id @default(cuid())
  guildId          String   @unique
  
  approvalChannelId String? // Channel where staff reviews intercepted messages
  
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  rules            ChannelRule[]

  @@map("channel_rule_settings")
}

model ChannelRule {
  id             String   @id @default(cuid())
  guildId        String
  settingsId     String
  
  name           String   // Friendly name (e.g. "No EXE files")
  targetChannelId String  // The channel this rule applies to
  
  type           String   // BLOCK_FILE_TYPES, MAX_LENGTH, REGEX_MATCH, etc.
  config         Json     // Stores specifics: { extensions: ['.exe'], length: 50, pattern: 'badword' }
  
  action         String   // BLOCK, REQUIRE_APPROVAL
  enabled        Boolean  @default(true)
  
  exemptRoles    String[] @default([]) // Roles that bypass this rule
  requiredRoles  String[] @default([]) // If set, rule ONLY applies to these roles
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  guild          Guild               @relation(fields: [guildId], references: [id], onDelete: Cascade)
  settings       ChannelRuleSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([guildId, targetChannelId])
  @@map("channel_rules")
}

model PendingReview {
  id             String   @id @default(cuid())
  guildId        String
  channelId      String   // Original channel to repost to
  userId         String   // Original author
  messageId      String   @unique // Original message ID
  
  username       String
  avatarUrl      String?
  content        String
  attachmentUrls String[] // Store valid Discord CDN urls from the admin embed
  
  ruleId         String   // Which rule triggered this
  status         String   @default("PENDING") // PENDING
  
  approvalMessageId String? // The ID of the message in the staff channel
  approvalChannelId String? // The ID of the staff channel

  createdAt      DateTime @default(now())
  
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@map("pending_reviews")
}

// --- Musician Profile Plugin ---

model MusicianProfile {
  id              String   @id @default(cuid())
  userId          String   @unique // Discord User ID
  username        String
  displayName     String?
  avatar          String?
  bio             String?  @db.Text
  location        String?
  contactEmail    String?
  collabStatus    Boolean  @default(false)
  
  // Gear & Setup
  primaryDAW      String?
  dawVersion      String?
  vsts            String[] @default([])
  hardware        String[] @default([])
  maxProjectSizeMb Int     @default(100) // Max project ZIP size in MB; bumped for paid users

  // Socials / Streaming (Stored as JSON for flexibility, validated via service)
  socials         Json?    @default("[]")

  // Tracks & Discoverability
  tracks          Track[]
  totalPlays      Int      @default(0)
  
  // Moderation
  status          String   @default("active") // "active" | "suspended" | "banned"
  statusReason    String?  // Admin-provided note for suspension/ban
  
  // Genres (Many-to-Many via Join Table)
  genres          ProfileGenre[]
  
  // Featured Content
  featuredTrackId    String?  @unique
  featuredTrack      Track?   @relation("FeaturedTrack", fields: [featuredTrackId], references: [id])
  featuredPlaylistId String?
  featuredPlaylist   Playlist? @relation("ProfileFeaturedPlaylist", fields: [featuredPlaylistId], references: [id], onDelete: SetNull)

  comments        Comment[]
  followers       ArtistFollow[]
  playlists       Playlist[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
  @@index([createdAt(sort: Desc)])        // Discovery: newest profiles
  @@index([totalPlays(sort: Desc)])      // Leaderboard: top artists by total plays
  @@map("musician_profiles")
}

model Track {
  id              String   @id @default(cuid())
  profileId       String
  title           String
  slug            String?  // URL identifier (e.g., 'hey-brother')
  description     String?  @db.Text
  url             String   // Audio file URL (S3/Cloudinary)
  coverUrl        String?  // Cover image URL
  
  duration        Int      @default(0) // In seconds
  playCount       Int      @default(0)
  isPublic        Boolean  @default(true)
  allowAudioDownload Boolean @default(true)
  allowProjectDownload Boolean @default(true)

  // Moderation
  status          String   @default("active") // "active" | "suspended" | "deleted"
  statusReason    String?  // Admin-provided note

  // ID3 Metadata (user-editable)
  artist          String?
  album           String?
  year            Int?
  bpm             Int?
  key             String?  // Musical key, e.g. "Am", "C#"

  // Project Viewer (Splice-style timeline)
  arrangement     Json?    // Parsed FLP arrangement data: { bpm, tracks, clips }
  projectFileUrl  String?  // URL to the original .flp download
  projectZipUrl   String?  // URL to the uploaded .zip project package (R2)
  projectFileSizeBytes Int? // Size of uploaded project ZIP in bytes

  // Waveform data (generated on upload from main audio file)
  waveformPeaks   Json?    // number[] ~200 normalised RMS values, 0.0–1.0

  samples         TrackSample[]
  
  profile         MusicianProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  isFeaturedIn    MusicianProfile? @relation("FeaturedTrack")
  plays           TrackPlay[]
  genres          TrackGenre[]
  battleEntries   BattleEntry[]
  comments        Comment[]
  favourites      TrackFavourite[]
  reposts         TrackRepost[]
  playlistTracks  PlaylistTrack[]
  radioQueues     RadioQueue[]
  radioHistories  RadioHistory[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([profileId])
  @@index([slug])
  @@index([profileId, isPublic, playCount(sort: Desc)])          // Fast per-profile top-track lookup
  @@index([isPublic, playCount(sort: Desc)])                     // Leaderboard: top public tracks by plays
  @@index([isPublic, createdAt(sort: Desc)])                     // Discovery: newest public tracks
  @@index([isPublic, status, playCount(sort: Desc)])             // Leaderboard with status filter
  @@index([isPublic, status, createdAt(sort: Desc)])             // Discovery with status filter
  @@map("musician_tracks")
}

model TrackPlay {
  id              String   @id @default(cuid())
  trackId         String
  userId          String?  // Optional: ID of user who played (null for guests)
  ipAddress       String   // Anti-cheat: Track IP to prevent botting
  userAgent       String?  // Anti-cheat: Track browser to prevent botting
  playAt          DateTime @default(now())
  durationPlayed  Int?     // How many seconds they actually listened
  
  track           Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([ipAddress, trackId, playAt]) // For fast anti-cheat lookups
  @@map("track_plays")
}

model TrackSample {
  id               String   @id @default(cuid())
  trackId          String
  originalFilename String   // Basename matched to FLP clip sampleFileName
  oggUrl           String   // R2 CDN URL (or local /uploads/samples/ path if R2 not configured)
  peaks            Json     // number[] ~1200 normalised RMS values, 0.0–1.0
  duration         Float?   // Duration in seconds
  track            Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([trackId, originalFilename])
  @@map("track_samples")
}

model Genre {
  id              String   @id @default(cuid())
  name            String   @unique
  slug            String   @unique
  description     String?
  
  // Hierarchical structure (Category > Parent > Sub-genre)
  parentId        String?
  parent          Genre?   @relation("GenreHierarchy", fields: [parentId], references: [id])
  children        Genre[]  @relation("GenreHierarchy")

  // Relations
  profiles        ProfileGenre[]
  tracks          TrackGenre[]

  @@map("genres")
}

model ProfileGenre {
  profileId       String
  genreId         String
  
  profile         MusicianProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  genre           Genre           @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([profileId, genreId])
  @@index([genreId])
  @@map("profile_genres")
}

model TrackGenre {
  trackId         String
  genreId         String
  
  track           Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  genre           Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([trackId, genreId])
  @@index([genreId])
  @@map("track_genres")
}

model DiscoverySettings {
  id              String   @id @default("singleton")
  featuredType    String   @default("track") // 'track' | 'artist' | 'playlist'
  featuredTrackId String?  // Global featured track on the discovery page
  featuredArtistId String? // Featured artist userId
  featuredPlaylistId String? // Featured playlist ID
  featuredLabel   String?  // Custom label for the featured section
  featuredDescription String?  @db.Text // Custom description shown under the hero title

  // Editor's Picks (JSON array of track IDs curated by admins)
  editorPickTrackIds Json?  @default("[]")

  // Featured Producer (separate from the hero featured artist)
  featuredProducerId   String?  // userId of highlighted producer
  featuredProducerNote String?  @db.Text // Custom blurb about the producer

  // Featured Battle
  featuredBattleId          String?  // BeatBattle ID to show on frontpage
  featuredBattleDescription String?  @db.Text // Custom blurb for the battle card

  // Featured Content (card type selector — 'video' | 'news' | 'guide')
  featuredContentType         String   @default("video") @map("featured_content_type")

  // Featured Tutorial / Video
  featuredTutorialUrl         String?  // YouTube/video embed URL
  featuredTutorialTitle       String?
  featuredTutorialDescription String?  @db.Text // Short blurb shown on the tutorial card
  featuredTutorialThumbnail   String?  // Thumbnail image URL
  featuredTutorialAuthor      String?  @map("featured_tutorial_author") // Name of the staff member / creator
  featuredTutorialDate        String?  @map("featured_tutorial_date")   // Display date string (e.g. "March 23, 2026")

  updatedAt       DateTime @updatedAt

  @@map("discovery_settings")
}

// Fuji Studio - Cloud Sample Manager
model SamplePack {
  id              String   @id @default(cuid())
  guildId         String   // Channel/Pack logic: Storage Guild ID
  channelId       String?  @unique // Old single-channel pack logic
  forumId         String?  // Tier 2: Forum ID
  threadId        String?  @unique // Tier 3: Thread ID (Specific Pack)
  category        String?  // Tier 1: Category Name
  name            String   // Pack name (usually channel or thread name)
  description     String?
  thumbnailUrl    String?
  creatorId       String?  // Original uploader/owner Discord ID
  isPublic        Boolean  @default(true)
  
  samples         SampleMetadata[]
  collections     SampleCollectionItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([guildId, category])
  @@map("fuji_sample_packs")
}

model SampleMetadata {
  id              String   @id @default(cuid())
  packId          String
  messageId       String?  // Discord Message ID
  attachmentId    String   @unique // Discord Attachment ID
  
  filename        String
  filesize        Int
  mimetype        String
  url             String   @default("") // CDN URL
  
  duration        Float?   // Seconds
  bpm             Int?
  key             String?
  isLoop          Boolean  @default(false)
  
  // Search vector
  tags            String[] @default([])
  authorId        String?  // Uploader Discord ID
  
  // Project Viewer (Splice-style Arrangement)
  arrangement     Json?    // Array of FLPClip objects for timeline visualization
  projectFile     ProjectFile?

  pack            SamplePack @relation(fields: [packId], references: [id], onDelete: Cascade)
  favoritedBy     UserSampleFavorite[]
  inCollections   SampleCollectionItem[]

  createdAt       DateTime @default(now())

  @@index([packId, filename, bpm, key])
  @@map("fuji_samples")
}

model ProjectFile {
  id              String   @id @default(cuid())
  sampleId        String   @unique
  sample          SampleMetadata @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  
  filename        String
  url             String
  filesize        Int
  mimetype        String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("fuji_project_files")
}

model UserSampleFavorite {
  id              String   @id @default(cuid())
  userId          String   // Discord User ID
  sampleId        String
  
  sample          SampleMetadata @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@unique([userId, sampleId])
  @@map("fuji_user_favorites")
}

model SampleCollection {
  id              String   @id @default(cuid())
  userId          String   // Discord User ID
  name            String
  description     String?
  isPublic        Boolean  @default(false)
  shareCode       String?  @unique @default(cuid())
  
  items           SampleCollectionItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("fuji_sample_collections")
}

model SampleCollectionItem {
  id              String   @id @default(cuid())
  collectionId    String
  sampleId        String
  packId          String?  // Shortcut
  createdAt       DateTime @default(now())

  collection      SampleCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  sample          SampleMetadata   @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  pack            SamplePack?      @relation(fields: [packId], references: [id])

  @@unique([collectionId, sampleId])
  @@map("fuji_collection_items")
}

// ──────────────────────────────────────────────
// Beat Battle Plugin
// ──────────────────────────────────────────────

model BeatBattle {
  id                  String   @id @default(cuid())
  slug                String?  @unique
  guildId             String
  title               String
  description         String?  @db.Text
  status              String   @default("upcoming") // upcoming | active | voting | completed
  rules               String?  @db.Text
  rulesData           Json?    // Array of { text, links: {label,url}[], samples: {name,url}[] }

  // Scheduling
  submissionStart     DateTime?
  submissionEnd       DateTime?
  votingStart         DateTime?
  votingEnd           DateTime?

  // Discord integration
  announcementChannelId String? // Where announcements go

  // Winner
  winnerEntryId       String?  // Winning BattleEntry ID

  // Prizes
  prizes              Json?    // Array of { place: string, description: string }

  // Voting
  maxVotesPerUser     Int      @default(0) // 0 = unlimited, 1+ = max entries a single user can vote on

  // Announcement
  pendingAnnouncement Boolean  @default(false) // Set true to trigger bot announcement on next lifecycle check

  // Sponsor
  sponsorId           String?

  // Media
  bannerUrl           String?  // Admin-uploaded hero banner image
  cardImageUrl        String?  // Homepage card image (shown in battle card on discovery page)

  // Submission options
  requireProjectFile  Boolean  @default(false) // Require .flp/.zip project upload

  createdBy           String   // Admin Discord ID who created
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  guild               Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  sponsor             BattleSponsor? @relation(fields: [sponsorId], references: [id])
  entries             BattleEntry[]
  analytics           BattleAnalytics[]

  @@index([guildId])
  @@index([status])
  @@map("beat_battles")
}

model BattleEntry {
  id          String   @id @default(cuid())
  battleId    String
  userId      String   // Discord user ID
  username    String   // Cached display name
  trackTitle  String
  audioUrl    String   // Path to uploaded audio
  coverUrl    String?  // Optional cover art
  avatarUrl   String?  // Submitter's Discord avatar URL
  description String?  @db.Text // Optional description
  projectUrl  String?  // Optional project file (.flp/.zip) URL
  duration    Int      @default(0) // seconds
  bpm         Int?
  key         String?
  artist      String?
  arrangement Json?              // Parsed FLP arrangement data
  voteCount   Int      @default(0) // Denormalized for perf
  trackId     String?  // FK to musician Track (library submission)
  source      String   @default("web")
  createdAt   DateTime @default(now())

  battle      BeatBattle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  track       Track?       @relation(fields: [trackId], references: [id], onDelete: SetNull)
  votes       BattleVote[]

  @@unique([battleId, userId]) // One entry per battle per user
  @@index([battleId])
  @@index([userId])
  @@map("battle_entries")
}

model BattleVote {
  id        String   @id @default(cuid())
  entryId   String
  userId    String   // Discord user ID
  source    String   @default("web") // web | discord
  createdAt DateTime @default(now())

  entry     BattleEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId]) // One vote per entry per user
  @@index([entryId])
  @@map("battle_votes")
}

model BattleSponsor {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  logoUrl     String?
  websiteUrl  String?
  description String?  @db.Text
  isActive    Boolean  @default(true)
  showOnPage  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  battles     BeatBattle[]
  links       BattleSponsorLink[]

  @@index([guildId])
  @@map("battle_sponsors")
}

model BattleSponsorLink {
  id          String   @id @default(cuid())
  sponsorId   String
  label       String   // e.g. "Visit Website", "Get 20% Off"
  url         String
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  sponsor     BattleSponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
  @@map("battle_sponsor_links")
}

model BattleAnalytics {
  id            String   @id @default(cuid())
  battleId      String
  eventType     String   // page_view | embed_view | sponsor_click | vote_cast | submission
  userId        String?  // Discord user ID if known
  metadata      Json?    // Additional context (e.g., { linkId: "..." })
  createdAt     DateTime @default(now())

  battle        BeatBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@index([battleId])
  @@index([eventType])
  @@map("battle_analytics")
}

model BeatBattleSettings {
  id                    String   @id @default(cuid())
  guildId               String   @unique
  announcementChannelId String?
  chatChannelId         String?
  discordInviteUrl      String?
  featuredBattleId      String?
  sponsorSectionTitle   String?
  requireMusicianProfile Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  guild                 Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("beat_battle_settings")
}

// ──────────────────────────────────────────────
// Comments (Tracks + Profiles)
// ──────────────────────────────────────────────

model Comment {
  id              String   @id @default(cuid())
  userId          String   // Discord user ID of commenter
  username        String   // Cached display name
  avatarUrl       String?  // Cached avatar URL
  content         String   @db.Text // Text content (may contain emoji shortcodes)
  gifUrl          String?  // Tenor/Giphy GIF URL if attached
  editedAt        DateTime? // Set when edited

  // Polymorphic target: exactly one of these should be set
  trackId         String?  // Comment on a track
  profileId       String?  // Comment on a musician profile

  // Self-referential reply thread (one level deep)
  parentId        String?

  track           Track?           @relation(fields: [trackId], references: [id], onDelete: Cascade)
  profile         MusicianProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  parent          Comment?         @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies         Comment[]        @relation("CommentReplies")
  likes           CommentLike[]

  createdAt       DateTime @default(now())

  @@index([trackId])
  @@index([profileId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id              String   @id @default(cuid())
  userId          String   // Discord user ID
  commentId       String
  type            String   // "like" | "dislike"

  comment         Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

model CommentLog {
  id              String   @id @default(cuid())
  commentId       String   // Original comment ID
  action          String   // "created" | "edited" | "deleted"
  userId          String   // Who performed the action
  content         String?  @db.Text // Snapshot of content at time of action
  gifUrl          String?  // Snapshot of gif
  metadata        Json?    // Extra context (e.g. reason for delete)
  createdAt       DateTime @default(now())

  @@index([commentId])
  @@map("comment_logs")
}

// ──────────────────────────────────────────────
// Track Favourites (Likes)
// ──────────────────────────────────────────────

model TrackFavourite {
  id        String   @id @default(cuid())
  userId    String   // Discord user ID
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, trackId])
  @@index([trackId])
  @@index([userId])
  @@map("track_favourites")
}

model TrackRepost {
  id        String   @id @default(cuid())
  userId    String   // Discord user ID of reposter
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, trackId])
  @@index([trackId])
  @@index([userId])
  @@map("track_reposts")
}

// ──────────────────────────────────────────────
// Artist Follows
// ──────────────────────────────────────────────

model ArtistFollow {
  id        String          @id @default(cuid())
  followerId String         // Discord user ID of follower
  artistId  String          // MusicianProfile ID being followed
  artist    MusicianProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([followerId, artistId])
  @@index([artistId])
  @@index([followerId])
  @@map("artist_follows")
}

// ──────────────────────────────────────────────
// Music Notifications
// ──────────────────────────────────────────────

model MusicNotification {
  id          String   @id @default(cuid())
  userId      String   // Recipient Discord user ID
  type        String   // 'comment' | 'reply' | 'follow' | 'favourite'
  title       String
  message     String
  link        String?  // Path to redirect to (e.g. '/track/user/slug')
  actorId     String?  // Who caused the notification
  actorName   String?  // Cached actor display name
  actorAvatar String?  // Cached actor avatar URL
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("music_notifications")
}

// ──────────────────────────────────────────────
// Playlists
// ──────────────────────────────────────────────

model Playlist {
  id          String          @id @default(cuid())
  userId      String          // Discord user ID of creator
  profileId   String?         // Optional link to MusicianProfile
  profile     MusicianProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  name        String
  slug        String?
  description String?         @db.Text
  coverUrl    String?
  isPublic    Boolean         @default(true)
  releaseType String?         // 'album' | 'ep' | 'single' | null = plain playlist
  trackCount  Int             @default(0)
  totalPlays  Int             @default(0)
  tracks      PlaylistTrack[]
  featuredByProfiles MusicianProfile[] @relation("ProfileFeaturedPlaylist")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, slug])
  @@index([userId])
  @@index([isPublic, totalPlays])
  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int      // Sort order
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  addedAt    DateTime @default(now())

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

// ─── Charts System ───────────────────────────────────────────────────────────
// Snapshots taken periodically (e.g. daily) to track position changes over time.

model ChartSnapshot {
  id          String   @id @default(cuid())
  period      String   // "daily" | "weekly" | "alltime"
  takenAt     DateTime @default(now()) // When this snapshot was generated
  entries     ChartEntry[]

  @@index([period, takenAt])
  @@map("chart_snapshots")
}

model ChartEntry {
  id           String   @id @default(cuid())
  snapshotId   String
  trackId      String
  position     Int      // Rank in this snapshot (1 = #1)
  playCount    Int      // Play count at time of snapshot
  playsInPeriod Int     @default(0) // Plays gained during this period
  prevPosition Int?     // Position in the previous snapshot (null = new entry)
  peakPosition Int      @default(1) // Best position ever achieved
  weeksOnChart Int      @default(1) // How many snapshots this track appeared

  snapshot     ChartSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, trackId])
  @@unique([snapshotId, position])
  @@index([trackId])
  @@map("chart_entries")
}

// ─── Voice Monitor System ────────────────────────────────────────────────────

model VoiceMonitorSettings {
  id                  String   @id @default(cuid())
  guildId             String   @unique
  enabled             Boolean  @default(false)
  retentionDays       Int      @default(30)
  noticeChannelId     String?  // Channel where one-time recording notice was posted
  noticeSent          Boolean  @default(false)
  noticeMessageId     String?  // Discord message ID of the notice
  monitoredChannelIds String[] // Empty = all voice channels
  excludedRoleIds     String[] // Roles exempt from recording

  guild               Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  @@map("voice_monitor_settings")
}

model VoiceSession {
  id          String    @id @default(cuid())
  guildId     String
  channelId   String
  channelName String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  segments    VoiceSegment[]
  reports     VoiceReport[]

  @@index([guildId, startedAt(sort: Desc)])
  @@map("voice_sessions")
}

model VoiceSegment {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  userName    String?
  r2Key       String   // R2 object key: voice/{guildId}/{sessionId}/{userId}_{ts}.ogg
  r2Url       String   // CDN URL to the audio file
  durationMs  Int      @default(0)
  fileSize    Int      @default(0) // bytes
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  session     VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@map("voice_segments")
}

model VoiceReport {
  id          String   @id @default(cuid())
  guildId     String
  sessionId   String?
  reporterId  String
  reporterName String?
  targetId    String?  // Specific user being reported (null = whole session)
  targetName  String?
  reason      String
  status      String   @default("open") // open | reviewed | resolved | dismissed
  notes       String?  // Staff notes
  reviewedBy  String?  // Staff member who reviewed
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  guild       Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  session     VoiceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([guildId, status])
  @@index([guildId, createdAt(sort: Desc)])
  @@map("voice_reports")
}

// Anti-Piracy Plugin
// ──────────────────────────────────────────────
// Leveling Plugin
// ──────────────────────────────────────────────

model LevelingSettings {
  id                 String   @id @default(cuid())
  guildId            String   @unique

  enabled            Boolean  @default(true)

  // XP Sources toggles
  messageXpEnabled   Boolean  @default(true)
  voiceXpEnabled     Boolean  @default(true)
  reactionXpEnabled  Boolean  @default(true)

  // XP Rates
  xpMultiplier       Float    @default(1.0)
  messageXpMin       Int      @default(15)
  messageXpMax       Int      @default(25)
  voiceXpPerMinute   Int      @default(5)
  reactionGivenXp    Int      @default(3)
  reactionReceivedXp Int      @default(5)

  // Cooldowns
  messageCooldownSec Int      @default(60)

  // Channels
  levelUpChannelId   String?
  blacklistedChannels String[] @default([])
  blacklistedRoles    String[] @default([])

  // Notifications
  levelUpMessage     String   @default("{user} leveled up to **Level {level}**! 🎉")
  announceRoleReward Boolean  @default(true)

  // ── Economy Synergy ──
  economyRewardsEnabled  Boolean  @default(false)
  levelUpCurrencyReward  Int      @default(50)       // Coins awarded per level-up
  milestoneLevels        Json     @default("[]")      // e.g. [{"level":10,"reward":500},{"level":25,"reward":2000}]
  microRewardsEnabled    Boolean  @default(false)
  microRewardAmount      Int      @default(5)         // Coins per micro-reward trigger
  microRewardReactions   Int      @default(10)        // Reactions needed to trigger micro-reward
  microRewardVoiceMin    Int      @default(10)        // Voice minutes needed to trigger micro-reward
  activityScalingEnabled Boolean  @default(false)     // +2% economy earnings per 5 levels
  xpBoosterEnabled       Boolean  @default(false)
  xpBoosterPrice         Int      @default(500)       // Cost to buy 1h XP booster
  xpBoosterMultiplier    Float    @default(1.5)       // Booster multiplier
  xpBoosterDurationMin   Int      @default(60)        // Booster duration in minutes

  // Role rewards
  roleRewards        LevelRoleReward[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  guild              Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("leveling_settings")
}

model LevelRoleReward {
  id         String   @id @default(cuid())
  settingsId String
  level      Int
  roleId     String
  sticky     Boolean  @default(true) // Restore on rejoin

  settings   LevelingSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, level])
  @@map("level_role_rewards")
}

model XpBooster {
  id         String   @id @default(cuid())
  guildId    String
  userId     String
  multiplier Float    @default(1.5)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([guildId, userId])
  @@map("xp_boosters")
}

model AntiPiracySettings {
  id               String   @id @default(cuid())
  guildId          String   @unique

  enabled          Boolean  @default(true)
  aiEnabled        Boolean  @default(true)
  actionType       String   @default("delete_and_warn") // warn | delete | delete_and_warn
  reminderMessage  String   @default("Piracy discussion is not allowed in this server. Please support developers by purchasing software legally.")

  excludedChannels String[] @default([])
  excludedRoles    String[] @default([])
  customKeywords   String[] @default([])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("anti_piracy_settings")
}

// ─── Fuji FM / Radio ────────────────────────────────────────────────────────

model RadioSettings {
  id                  String   @id @default(cuid())
  guildId             String   @unique

  enabled             Boolean  @default(true)
  voiceChannelId      String?           // Dedicated radio VC
  textChannelId       String?           // #radio-chat for now-playing embeds
  nowPlayingMessageId String?           // Persistent embed message ID

  // Auto-Pilot settings
  autoEnabled         Boolean  @default(true)   // 24/7 auto-radio
  autoSource          String   @default("trending") // trending | newest | random | genre
  autoGenreFilter     String?           // Genre slug for genre rotation
  ttsAnnounce         Boolean  @default(true)    // TTS announce before songs

  // Ad injection
  adsEnabled          Boolean  @default(false)
  adFrequency         Int      @default(5)       // Play ad every N songs
  adTtsDefault        String   @default("This hour of Fuji FM is brought to you by the community!")

  // Listener XP
  listenerXpEnabled   Boolean  @default(false)
  listenerXpPerMinute Int      @default(1)

  // Economy tip integration
  tipEnabled          Boolean  @default(true)
  minTipAmount        Int      @default(1)

  // Volume
  defaultVolume       Float    @default(0.5)     // 0.0 - 1.0
  duckVolume          Float    @default(0.15)    // Volume during host speech

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  guild               Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("radio_settings")
}

model RadioQueue {
  id          String   @id @default(cuid())
  guildId     String
  trackId     String
  addedBy     String?          // User who queued it (null = auto)
  position    Int              // Order in queue
  isAd        Boolean  @default(false)
  adText      String?          // TTS ad text
  adAudioUrl  String?          // Uploaded ad audio clip
  playedAt    DateTime?
  skipped     Boolean  @default(false)

  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([guildId, position])
  @@map("radio_queue")
}

model RadioHistory {
  id          String   @id @default(cuid())
  guildId     String
  trackId     String?
  trackTitle  String
  artistName  String
  coverUrl    String?
  duration    Int      @default(0)
  listenCount Int      @default(0)   // Members in VC during play
  isAd        Boolean  @default(false)
  hostedBy    String?               // Host user ID if in host mode

  track       Track?   @relation(fields: [trackId], references: [id], onDelete: SetNull)
  playedAt    DateTime @default(now())

  @@index([guildId, playedAt])
  @@map("radio_history")
}

model RadioAdSlot {
  id          String   @id @default(cuid())
  guildId     String
  userId      String               // Who bought it
  adType      String   @default("tts") // tts | audio
  adText      String?              // TTS message
  audioUrl    String?              // Uploaded audio clip URL
  costPaid    Int      @default(0) // Economy points spent
  playsLeft   Int      @default(3) // How many plays remaining
  approved    Boolean  @default(false) // Mod-approved
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())

  @@index([guildId, active])
  @@map("radio_ad_slots")
}

// ─── Studio Guide ─────────────────────────────────────────────────────────────

model StudioGuideSettings {
  id                String   @id @default(cuid())
  guildId           String   @unique

  enabled           Boolean  @default(true)
  channelId         String?              // Single channel the bot monitors
  pauseRoles        String[] @default([]) // Roles that can pause the bot
  cooldownSeconds   Int      @default(30) // Per-user cooldown between AI answers
  systemPrompt      String?              // Custom system prompt override
  model             String   @default("gpt-4o-mini")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  guild             Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  conversations     StudioGuideConversation[]

  @@map("studio_guide_settings")
}

model StudioGuideConversation {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  userId      String
  settingsId  String

  // Conversation history stored as JSON array of {role, content} messages
  messages    Json     @default("[]")
  topic       String?              // AI-generated summary of the conversation topic
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    StudioGuideSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, userId, active])
  @@map("studio_guide_conversations")
}
