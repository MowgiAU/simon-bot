// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Managed by connect-pg-simple — Prisma must not drop this table.
model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@ignore
  @@map("session")
}

// --- User Accounts (Native auth with optional Discord linking) ---
model User {
  id                      String    @id @default(cuid())
  discordId               String?   @unique
  email                   String?   @unique
  emailVerified           DateTime?
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?
  username                String    @unique
  displayName             String?
  avatar                  String?
  passwordHash            String?
  lastLoginAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // 2FA (TOTP)
  totpSecret      String? // Encrypted TOTP secret
  totpEnabled     Boolean  @default(false)
  totpBackupCodes String[] @default([]) // Hashed backup codes

  // Account recovery
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  // Pending email change (verified before applying)
  pendingEmail       String?
  pendingEmailToken  String?   @unique
  pendingEmailExpiry DateTime?

  // Access control for invite-only beta
  role    String  @default("user") // "user" | "admin" | "moderator"
  invited Boolean @default(false) // Invite-only gate for private beta

  // Support ticket system
  isTicketBlocked Boolean @default(false)

  // Vote fraud / account ban
  banned    Boolean   @default(false)
  bannedAt  DateTime?
  bannedFor String?   // Reason (e.g. "vote_fraud")

  // Soft delete
  deletedAt DateTime?

  storageQuotaBytes BigInt  @default(1073741824) // 1 GB free tier
  storageTier       String  @default("free")     // "free" | "pro" | "unlimited"

  projects                 Project[]
  desktopTokens            DesktopToken[]
  deviceTokens             DeviceToken[]
  notificationPreferences  NotificationPreferences?
  apkDownloads             ApkDownload[]
  sessions                 UserSession[]

  @@map("users")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Social interactions
  comments         Boolean @default(true)
  replies          Boolean @default(true)
  likes            Boolean @default(true)
  reposts          Boolean @default(true)
  follows          Boolean @default(true)
  messages         Boolean @default(true)

  // Feed
  followedUploads  Boolean @default(true)
  newTracksGlobal  Boolean @default(false)

  // Battles
  battleResults    Boolean @default(true)
  h2hUpdates       Boolean @default(true)

  // News by category
  newsNews         Boolean @default(true)
  newsGuide        Boolean @default(true)
  newsAnnouncement Boolean @default(true)
  newsTutorial     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_preferences")
}

// Guild configuration
model Guild {
  id        String   @id
  name      String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members         Member[]
  wordGroups      WordGroup[]
  filterSettings  FilterSettings?
  channelStats    ChannelStats[]
  serverStats     ServerStats[]
  pluginSettings  PluginSettings[]
  dashboardAccess DashboardAccess?
  actionLogs      ActionLog[]
  userNotes       UserNote[]

  // Channel Rules
  channelRuleSettings ChannelRuleSettings?
  channelRules        ChannelRule[]
  pendingReviews      PendingReview[]

  moderationSettings   ModerationSettings?
  moderationWarnings   ModerationWarning[]
  boosterColorSettings BoosterColorSettings?
  welcomeGateSettings  WelcomeGateSettings?

  economyAccounts    EconomyAccount[]
  economySettings    EconomySettings?
  economyItems       EconomyItem[]
  economyInventory   EconomyInventory[]
  economyTrans       EconomyTransaction[]
  economyPurchaseLog EconomyPurchaseLog[]
  economyTokenGrants EconomyTokenGrant[]

  // Feedback Plugin
  feedbackProfiles FeedbackProfile[]
  feedbackPosts    FeedbackPost[]
  feedbackSettings FeedbackSettings?
  echoSettings     EchoSettings?
  feedbackPoints   FeedbackPoints[]
  feedbackPointsTransactions FeedbackPointsTransaction[]

  // Ticket System
  ticketSettings TicketSettings?
  tickets        Ticket[]

  // Beat Battle
  beatBattles        BeatBattle[]
  battleSponsors     BattleSponsor[]
  beatBattleSettings BeatBattleSettings?

  // Leveling
  levelingSettings LevelingSettings?

  // Anti-Piracy
  antiPiracySettings AntiPiracySettings?

  // Radio
  radioSettings RadioSettings?

  // Studio Guide
  studioGuideSettings         StudioGuideSettings?
  studioGuideKnowledge        StudioGuideKnowledge[]
  studioGuideOptOuts          StudioGuideOptOut[]
  autoMessageSchedules        AutoMessageSchedule[]
  autoResponderRules          AutoResponderRule[]
  autoResponderSettings       AutoResponderSettings?
  autoResponderCategories     AutoResponderCategory[]
  pauseSettings               PauseSettings?
  serverBoostSettings         ServerBoostSettings?
  reactionRoles               ReactionRole[]
  articles                    Article[]
  voiceStatSettings           VoiceStatSettings?
  spamGuardSettings           SpamGuardSettings?
  spamGuardIncidents          SpamGuardIncident[]
  antiExternalForwardSettings AntiExternalForwardSettings?
  trackAnnouncerSettings      TrackAnnouncerSettings?

  // Academy
  academySettings AcademySettings?

  // Head-to-Head Battles
  headToHeadSettings HeadToHeadSettings?

  // Slot Machine
  slotMachineSettings   SlotMachineSettings?
  slotPot               SlotPot?
  slotDailyTrackers     SlotDailyTracker[]
  slotReturns           SlotReturn[]


  @@map("guilds")
}

// Bot Identity Settings
model BotSettings {
  botId        String   @id
  status       String   @default("online")
  activityType String   @default("PLAYING")
  activityText String?
  username     String?
  avatarUrl    String?
  updatedAt    DateTime @updatedAt

  @@map("bot_settings")
}

// Moderation Settings
model ModerationSettings {
  id           String  @id @default(cuid())
  guildId      String  @unique
  logChannelId String? // Channel to send nice embeds to
  dmUponAction Boolean @default(true) // DM user when kicked/banned?

  // Custom Messages
  kickMessage    String? // e.g. "You were kicked from {server} for: {reason}"
  banMessage     String?
  timeoutMessage String?

  // Case File Forum
  caseLogForumId String? // Forum channel ID for per-user case file threads

  // Remove command alert role
  removeAlertRoleId String? // Role to ping when jr staff uses /remove

  permissions ModerationPermission[]

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("moderation_settings")
}

model BlocklistedUser {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  username  String? // Denormalized Discord username/tag for dashboard display
  reason    String?
  addedBy   String? // Discord ID of mod who added the entry
  createdAt DateTime @default(now())

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("blocklisted_users")
}

model CoinDrainer {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  username  String?
  reason    String?
  addedBy   String?
  createdAt DateTime @default(now())

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("coin_drainers")
}

model ModerationPermission {
  id         String @id @default(cuid())
  settingsId String
  roleId     String // Discord Role ID

  // Permissions
  canWarn     Boolean @default(false)
  canKick     Boolean @default(false)
  canBan      Boolean @default(false)
  canTimeout  Boolean @default(false)
  canPurge    Boolean @default(false)
  canRemove   Boolean @default(false)
  canViewLogs Boolean @default(false)

  settings ModerationSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, roleId])
  @@map("moderation_permissions")
}

model ModerationWarning {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  reason    String
  issuedBy  String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("moderation_warnings")
}

model BoosterColorSettings {
  id            String   @id @default(cuid())
  guildId       String   @unique
  boosterRoleId String? // Optional: if set, checks this role instead of premiumSince
  colorRoleIds  String[] @default([])

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("booster_color_settings")
}

// ---------------------------------------------------------
// Existing Models Below
// ---------------------------------------------------------

// Action Logs for Auditing
model ActionLog {
  id             String   @id @default(cuid())
  guildId        String
  pluginId       String // e.g., 'word-filter', 'moderation'
  action         String // e.g., 'message_deleted', 'user_banned'
  executorId     String? // ID of user/bot who performed action
  targetId       String? // ID of user/message/channel affected
  details        Json? // Context specific data
  searchableText String   @default("") // Quick search vector (names, ids, content)
  createdAt      DateTime @default(now())

  guild    Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  comments LogComment[]

  @@index([guildId, createdAt])
  @@map("action_logs")
}

model LogComment {
  id        String   @id @default(cuid())
  logId     String
  userId    String // Admin who made the comment
  content   String
  createdAt DateTime @default(now())

  log ActionLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@index([logId])
  @@map("log_comments")
}

model UserNote {
  id        String   @id @default(cuid())
  guildId   String
  userId    String // The user being noted on
  adminId   String // Admin who made the note
  content   String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@map("user_notes")
}

model ScheduledTask {
  id        String   @id @default(cuid())
  guildId   String
  type      String // e.g. 'unban'
  targetId  String
  executeAt DateTime
  data      Json? // e.g. { "reason": "Time Served" }
  createdAt DateTime @default(now())

  @@index([executeAt])
  @@map("scheduled_tasks")
}

// Guild members - leveling, currency, etc.
model Member {
  id      String @id @default(cuid())
  guildId String
  userId  String

  // Leveling system
  level   Int @default(0)
  xp      Int @default(0)
  totalXp Int @default(0)

  // Leveling tracking
  voiceMinutes      Int       @default(0)
  messagesCount     Int       @default(0)
  reactionsGiven    Int       @default(0)
  reactionsReceived Int       @default(0)
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastMessageAt     DateTime?
  lastDailyAt       DateTime?
  earnedRoles       String[]  @default([])

  // Currency system
  balance Int @default(0)

  // Tracking
  lastActiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  guild           Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  feedbackProfile FeedbackProfile?

  @@unique([guildId, userId])
  @@index([guildId, totalXp])
  @@index([guildId, voiceMinutes])
  @@map("members")
}

// Word Filter Plugin
model FilterSettings {
  id      String @id @default(cuid())
  guildId String @unique

  // Global settings
  enabled       Boolean @default(true)
  repostEnabled Boolean @default(true)

  // Excluded channels and roles (JSON arrays of IDs)
  excludedChannels String[] @default([])
  excludedRoles    String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  guild      Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  wordGroups WordGroup[]

  @@map("filter_settings")
}

model WordGroup {
  id      String @id @default(cuid())
  guildId String
  name    String // e.g., "Slurs", "Spam"

  // Replacement (word or emoji)
  replacementText  String?
  replacementEmoji String?
  useEmoji         Boolean @default(false)
  enabled          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  guild    Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  settings FilterSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade, map: "word_groups_settings_fkey")
  words    FilterWord[]

  @@unique([guildId, name])
  @@map("word_groups")
}

model FilterWord {
  id      String @id @default(cuid())
  groupId String
  word    String

  createdAt DateTime @default(now())

  // Relations
  group WordGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, word])
  @@map("filter_words")
}

// Statistics Models

model ChannelStats {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  channelName String
  date        DateTime @db.Date
  messages    Int      @default(0)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId, date])
  @@map("channel_stats")
}

model ServerStats {
  id           String   @id @default(cuid())
  guildId      String
  date         DateTime @db.Date
  memberCount  Int      @default(0)
  messageCount Int      @default(0)
  voiceMinutes Int      @default(0)
  newBans      Int      @default(0)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, date])
  @@map("server_stats")
}

// Plugin Management
model PluginSettings {
  id       String @id @default(cuid())
  guildId  String
  pluginId String

  enabled      Boolean  @default(true)
  allowedRoles String[] @default([]) // Roles that can configure this plugin

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, pluginId])
  @@map("plugin_settings")
}

model DashboardAccess {
  id           String   @id @default(cuid())
  guildId      String   @unique
  allowedRoles String[] @default([]) // Roles that can login to dashboard
  betaRoleIds  String[] @default([]) // Roles that get auto-invited for beta access

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("dashboard_access")
}

// Internal Messaging & Notifications
model DashboardMessage {
  id          String   @id @default(cuid())
  guildId     String
  senderId    String // Discord User ID
  recipientId String? // Optional: Discord User ID (null means global/broadcast)
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([guildId, recipientId])
  @@index([guildId, senderId])
  @@map("dashboard_messages")
}

model Notification {
  id        String   @id @default(cuid())
  guildId   String
  userId    String // Recipient Discord User ID
  type      String // 'mention', 'message', 'system'
  title     String
  message   String
  link      String? // Optional path to redirect to (e.g., '/logs?id=123')
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([guildId, userId, isRead])
  @@map("dashboard_notifications")
}

// Economy System
model EconomyAccount {
  id          String    @id @default(cuid())
  guildId     String
  userId      String
  balance     Int       @default(0)
  totalEarned Int       @default(0) // Lifetime earnings
  nickOptOut  Boolean   @default(false) // Opt out of auto-nickname balance display
  lastDaily   DateTime?
  lastWeekly  DateTime?

  // Relations
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("economy_accounts")
}

model EconomySettings {
  id      String @id @default(cuid())
  guildId String @unique

  // Configuration
  currencyName  String @default("Coins")
  currencyEmoji String @default("🪙")

  // Earning
  messageReward    Int @default(5)
  messageCooldown  Int @default(60) // Seconds between message rewards
  minMessageLength Int @default(10)

  // Features
  autoNickname Boolean @default(false)
  allowTipping Boolean @default(true)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("economy_settings")
}

model EconomyItem {
  id      String @id @default(cuid())
  guildId String

  name        String
  description String?
  price       Int
  type        String // ROLE, EXTERNAL, ITEM, TOKEN
  category    String  @default("General")

  // Metadata for types
  // ROLE:  { roleId }
  // TOKEN: { roleId, durationDays }
  metadata Json?

  // Stock control
  stock      Int? // Null = infinite
  maxPerUser Int?

  // Per-user purchase limit (e.g. 1 purchase per 365 days)
  purchaseLimitCount Int? // max purchases allowed in the window (null = unlimited)
  purchaseLimitDays  Int? // rolling window in days (null = no window)

  createdAt DateTime @default(now())

  guild          Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  purchaseLog    EconomyPurchaseLog[]
  tokenGrants    EconomyTokenGrant[]

  @@unique([guildId, name]) // Unique names per guild
  @@map("economy_items")
}

// Tracks individual purchases for per-user limit enforcement
model EconomyPurchaseLog {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  itemId    String
  purchasedAt DateTime @default(now())

  item  EconomyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  guild Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId, itemId, purchasedAt])
  @@map("economy_purchase_log")
}

// Tracks active temporary role grants from TOKEN-type items
model EconomyTokenGrant {
  id        String    @id @default(cuid())
  guildId   String
  userId    String
  itemId    String
  roleId    String
  expiresAt DateTime
  removedAt DateTime? // null = still active

  item  EconomyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  guild Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([expiresAt, removedAt])
  @@map("economy_token_grants")
}

model EconomyInventory {
  id       String @id @default(cuid())
  guildId  String
  userId   String
  itemId   String
  quantity Int    @default(1)

  acquiredAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // No strict relation to item to allow keeping items if they are deleted from shop (legacy support)
  // But for now, let's keep it simple. If we delete from shop, maybe we want to keep it in inventory?
  // Let's create a relation but set OnDelete SetNull? Or just rely on ID string.
  // Using ID string is safer for "archived" items.

  @@unique([guildId, userId, itemId])
  @@map("economy_inventory")
}

model EconomyTransaction {
  id      String @id @default(cuid())
  guildId String

  fromUserId String? // Null if system
  toUserId   String? // Null if burning/system
  amount     Int
  type       String // MESSAGE, SHOP, TIP, DAILY, ADMIN
  reason     String?

  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, fromUserId])
  @@index([guildId, toUserId])
  @@map("economy_transactions")
}

// Feedback / AI Production System (New Plugin)
model FeedbackProfile {
  id      String @id @default(cuid())
  guildId String
  userId  String

  genre      String?
  daw        String?
  experience String?

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild  Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // We can treat Member as optional relation or just store IDs if Member not guaranteed
  // But strictly Member should exist.
  member Member @relation(fields: [guildId, userId], references: [guildId, userId], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("feedback_profiles")
}

model FeedbackPost {
  id        String  @id @default(cuid())
  guildId   String
  channelId String
  threadId  String?
  userId    String
  messageId String  @unique
  content   String

  hasAudio     Boolean @default(false)
  audioUrl     String?
  referenceUrl String? // URL of the thread starter audio (for comparison)

  aiScore  Int?
  aiState  String  @default("PENDING") // PENDING, APPROVED, DENIED, UNSURE, REJECTED
  aiReason String?

  postType String @default("COMMENT") // COMMENT, FEEDBACK

  moderationMessageId String? // ID of the message in the clean/mod-log channel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, aiState])
  @@map("feedback_posts")
}

model FeedbackSettings {
  id      String @id @default(cuid())
  guildId String @unique

  enabled         Boolean @default(false)
  forumChannelId  String?
  reviewChannelId String?
  modLogChannelId String?

  // Feedback Points system (separate from economy currency)
  feedbackPointsReward Int @default(1)  // Points earned for giving approved feedback
  feedbackPointsCost   Int @default(5) // Points required to post a feedback thread

  aiModel         String   @default("gpt-4o-mini")
  approverRoleIds String[] @default([])
  supportChannelId String?

  blockedUsers FeedbackBlock[]

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("feedback_settings")
}

model FeedbackBlock {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  reason    String?
  blockedBy String

  createdAt DateTime @default(now())

  settings FeedbackSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("feedback_blocks")
}

// Feedback Points - separate from economy currency
model EchoSettings {
  id      String @id @default(cuid())
  guildId String @unique

  enabled            Boolean  @default(false)
  impersonateUser    Boolean  @default(true)       // post via webhook as original author
  triggerChance      Int      @default(10)          // % chance per message to queue an echo (1-100)
  minDelaySeconds    Int      @default(300)         // minimum wait before echoing (seconds)
  maxDelaySeconds    Int      @default(1800)        // maximum wait
  lookbackMessages   Int      @default(50)          // how many recent messages to pick from
  channelIds         String[] @default([])          // empty = all text channels
  blacklistUserIds   String[] @default([])          // never echo these users
  whitelistUserIds   String[] @default([])          // if non-empty, only echo these users

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("echo_settings")
}

model FeedbackPoints {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  balance   Int      @default(0)
  totalEarned Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("feedback_points")
}

// Feedback Points Transaction Log
model FeedbackPointsTransaction {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  amount      Int      // Positive = earned, Negative = spent
  type        String   // EARNED_FEEDBACK, SPENT_POST, BONUS, PENALTY
  reason      String?
  threadId    String? // Optional link to thread
  messageId   String? // Optional link to message

  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([guildId, createdAt])
  @@map("feedback_points_transactions")
}

// Welcome Gate System
model WelcomeGateSettings {
  id      String  @id @default(cuid())
  guildId String  @unique
  enabled Boolean @default(false)

  welcomeChannelId String?
  unverifiedRoleId String?
  verifiedRoleId   String?

  questions             String[] // Array of questions
  modalTitle            String   @default("Server Verification")
  logChannelId          String? // Channel to log blocked unverified messages
  departureChannelId    String? // Channel to announce member departures
  arrivalChannelId      String? // Channel to announce member arrivals
  whitelistedChannelIds String[] // Channels unverified users can still see

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("welcome_gate_settings")
}

// Ticket System
model TicketSettings {
  id                  String   @id @default(cuid())
  guildId             String   @unique
  ticketCategoryId    String?
  staffRoleIds        String[]
  transcriptChannelId String?
  ticketMessage       String?  @default("Click the button below to open a ticket")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("ticket_settings")
}

model Ticket {
  id        String    @id @default(cuid())
  channelId String    @unique
  guildId   String
  ownerId   String
  ownerName String?
  status    String    @default("open")
  priority  String    @default("low") // low, medium, high
  type      String    @default("discord") // "discord" | "web"
  subject   String?   // Subject line for web-originated tickets

  createdAt DateTime  @default(now())
  closedAt  DateTime?

  // Soft delete
  deletedAt DateTime?

  guild    Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([ownerId])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String
  authorName  String
  content     String
  attachments String? // Stored as JSON string or comma-separated
  createdAt   DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// Channel Rules & Moderation (Gatekeeper)
model ChannelRuleSettings {
  id      String @id @default(cuid())
  guildId String @unique

  approvalChannelId String? // Channel where staff reviews intercepted messages

  guild Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  rules ChannelRule[]

  @@map("channel_rule_settings")
}

model ChannelRule {
  id         String @id @default(cuid())
  guildId    String
  settingsId String

  name            String // Friendly name (e.g. "No EXE files")
  reason          String? // Custom reason shown to user when blocked (falls back to name)
  targetChannelId String // The channel this rule applies to

  type   String // BLOCK_FILE_TYPES, MAX_LENGTH, REGEX_MATCH, etc.
  config Json // Stores specifics: { extensions: ['.exe'], length: 50, pattern: 'badword' }

  action  String // BLOCK, REQUIRE_APPROVAL
  enabled Boolean @default(true)

  exemptRoles   String[] @default([]) // Roles that bypass this rule
  requiredRoles String[] @default([]) // If set, rule ONLY applies to these roles

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild    Guild               @relation(fields: [guildId], references: [id], onDelete: Cascade)
  settings ChannelRuleSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([guildId, targetChannelId])
  @@map("channel_rules")
}

model PendingReview {
  id        String @id @default(cuid())
  guildId   String
  channelId String // Original channel to repost to
  userId    String // Original author
  messageId String @unique // Original message ID

  username       String
  avatarUrl      String?
  content        String
  attachmentUrls String[] // Store valid Discord CDN urls from the admin embed

  ruleId String // Which rule triggered this
  status String @default("PENDING") // PENDING

  approvalMessageId String? // The ID of the message in the staff channel
  approvalChannelId String? // The ID of the staff channel

  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("pending_reviews")
}

// --- Musician Profile Plugin ---

model MusicianProfile {
  id           String  @id @default(cuid())
  userId       String  @unique // Discord User ID
  username     String
  displayName  String?
  avatar       String?
  bannerUrl    String? // User-uploaded hero banner image for profile page
  accentColor  String? // User-chosen hex accent color for their profile page (e.g. "#FF5500")
  cardBgColor  String? // User-chosen card background hex color (e.g. "#0A1628")
  bio          String? @db.Text
  location     String?
  contactEmail String?
  collabStatus Boolean @default(false)

  // Gear & Setup
  primaryDAW       String?
  dawVersion       String?
  vsts             String[] @default([])
  hardware         String[] @default([])
  maxProjectSizeMb Int      @default(100) // Max project ZIP size in MB; bumped for paid users

  // Socials / Streaming (Stored as JSON for flexibility, validated via service)
  socials Json? @default("[]")

  // Tracks & Discoverability
  tracks     Track[]
  totalPlays Int     @default(0)

  // Moderation
  status       String  @default("active") // "active" | "suspended" | "banned"
  statusReason String? // Admin-provided note for suspension/ban

  // Soft delete
  deletedAt DateTime?

  // Genres (Many-to-Many via Join Table)
  genres         ProfileGenre[]
  primaryGenreId String?
  primaryGenre   Genre?         @relation("PrimaryGenre", fields: [primaryGenreId], references: [id], onDelete: SetNull)

  // Featured Content
  featuredTrackId    String?   @unique
  featuredTrack      Track?    @relation("FeaturedTrack", fields: [featuredTrackId], references: [id], onDelete: SetNull)
  featuredPlaylistId String?
  featuredPlaylist   Playlist? @relation("ProfileFeaturedPlaylist", fields: [featuredPlaylistId], references: [id], onDelete: SetNull)

  // Social / Competitive Display
  showH2HRank       Boolean  @default(false)       // Opt-in: show Arena Elo in profile sidebar
  featuredFriendIds String[] @default([])           // Up to 8 mutual-follow userIds to feature (MySpace Top 8)

  // Profile Layout & Section Visibility
  headerLayout        String  @default("left")      // "left" | "centered" | "minimal"
  trackDisplayStyle   String  @default("list")      // "list" | "cards" | "compact"
  showGearSection     Boolean @default(true)
  showSocialLinks     Boolean @default(true)
  showStatsBar        Boolean @default(true)
  showFeaturedFriends Boolean @default(true)

  comments       Comment[]
  followers      ArtistFollow[]
  playlists      Playlist[]
  collaborations TrackCollaborator[]

  callouts          CollabCallout[]
  collabRequests    CollabRequest[]
  initiatedProjects CollabProject[] @relation("CollabProjectInitiator")
  joinedProjects    CollabProject[] @relation("CollabProjectCollaborator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([createdAt(sort: Desc)]) // Discovery: newest profiles
  @@index([totalPlays(sort: Desc)]) // Leaderboard: top artists by total plays
  @@map("musician_profiles")
}

model Track {
  id          String  @id @default(cuid())
  profileId   String
  title       String
  slug        String? // URL identifier (e.g., 'hey-brother')
  description String? @db.Text
  url         String  // OGG Opus stream (primary, ~128kbps)
  mp3Url      String? // MP3 192kbps fallback for iOS Safari
  coverUrl    String? // Cover image URL

  duration             Int     @default(0) // In seconds
  playCount            Int     @default(0)
  isPublic             Boolean @default(true)
  allowAudioDownload   Boolean @default(true)
  allowProjectDownload Boolean @default(true)
  allowStemsDownload   Boolean @default(true)
  trackType            String  @default("original") // "original" | "remix" | "cover"
  position             Int     @default(0) // display order on profile timeline

  // Creative Commons license
  license String @default("all-rights-reserved") // "all-rights-reserved" | "cc-by" | "cc-by-sa" | "cc-by-nc" | "cc-by-nc-sa" | "cc-by-nd" | "cc-by-nc-nd" | "cc0"

  // Moderation
  status       String  @default("active") // "active" | "suspended" | "deleted"
  statusReason String? // Admin-provided note

  // Soft delete
  deletedAt DateTime?

  // ID3 Metadata (user-editable)
  artist String?
  album  String?
  year   Int?
  bpm    Int?
  key    String? // Musical key, e.g. "Am", "C#"

  // Project Viewer (Splice-style timeline)
  arrangement          Json? // Parsed FLP arrangement data: { bpm, tracks, clips }
  projectFileUrl       String? // URL to the original .flp download
  projectZipUrl        String? // URL to the uploaded .zip project package (R2)
  projectFileSizeBytes Int? // Size of uploaded project ZIP in bytes
  audioFileSizeBytes   Int? // Size of uploaded audio file in bytes

  // Waveform data (generated on upload from main audio file)
  waveformPeaks Json? // number[] ~200 normalised RMS values, 0.0–1.0

  // Lyrics (plain text) and time-synced lyrics cues
  lyrics     String? @db.Text
  lyricsSync Json? // Array<{ time: number; text: string }> seconds-based cue list

  youtubeUrl String? // YouTube music video URL

  samples TrackSample[]
  stems   TrackStem[]

  profile        MusicianProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  isFeaturedIn   MusicianProfile? @relation("FeaturedTrack")
  plays          TrackPlay[]
  genres         TrackGenre[]
  battleEntries  BattleEntry[]
  comments       Comment[]
  favourites     TrackFavourite[]
  reposts        TrackRepost[]
  playlistTracks PlaylistTrack[]
  radioQueues    RadioQueue[]
  radioHistories RadioHistory[]
  collaborators  TrackCollaborator[]
  projectLink    ProjectTrackLink?
  genrePosts     GenrePost[]
  collabProject  CollabProject?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([profileId, position]) // profile timeline ordering
  @@index([slug])
  @@index([profileId, isPublic, playCount(sort: Desc)]) // Fast per-profile top-track lookup
  @@index([isPublic, playCount(sort: Desc)]) // Leaderboard: top public tracks by plays
  @@index([isPublic, createdAt(sort: Desc)]) // Discovery: newest public tracks
  @@index([isPublic, status, playCount(sort: Desc)]) // Leaderboard with status filter
  @@index([isPublic, status, createdAt(sort: Desc)]) // Discovery with status filter
  @@map("musician_tracks")
}

model TrackCollaborator {
  id           String    @id @default(cuid())
  trackId      String
  profileId    String    // Collaborator's MusicianProfile.id
  contribution String    // e.g. "vocals", "production", "guitar", "mixing"
  category     String    @default("collaboration") // "collaboration" | "1v1-battle" | "feature" | "remix" | "split"
  status       String    @default("pending") // "pending" | "accepted" | "rejected"
  invitedAt    DateTime  @default(now())
  respondedAt  DateTime?

  track   Track           @relation(fields: [trackId], references: [id], onDelete: Cascade)
  profile MusicianProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([trackId, profileId])
  @@index([profileId, status])
  @@map("track_collaborators")
}

model TrackPlay {
  id             String   @id @default(cuid())
  trackId        String
  userId         String? // Optional: ID of user who played (null for guests)
  ipAddress      String // Anti-cheat: Track IP to prevent botting
  userAgent      String? // Anti-cheat: Track browser to prevent botting
  playAt         DateTime @default(now())
  durationPlayed Int? // How many seconds they actually listened

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([ipAddress, trackId, playAt]) // For fast anti-cheat lookups
  @@map("track_plays")
}

model DownloadLog {
  id        String   @id @default(cuid())
  userId    String // Discord user ID of the downloader
  username  String? // Cached username at download time
  trackId   String? // Track ID if applicable
  fileType  String // "audio" | "project_flp" | "project_zip" | "sample"
  fileName  String? // Original/served filename
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([trackId])
  @@index([createdAt])
  @@map("download_logs")
}

model TrackSample {
  id               String   @id @default(cuid())
  trackId          String
  originalFilename String // Basename matched to FLP clip sampleFileName
  oggUrl           String // R2 CDN URL (or local /uploads/samples/ path if R2 not configured)
  peaks            Json // number[] ~1200 normalised RMS values, 0.0–1.0
  duration         Float? // Duration in seconds
  track            Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([trackId, originalFilename])
  @@map("track_samples")
}

// User-uploaded, individually-rendered stems (e.g. "Drums", "Bass", "Lead Synth")
// for a track — played back together in a synced multi-track mixer on the track page.
model TrackStem {
  id               String   @id @default(cuid())
  trackId          String
  label            String // User-facing name shown in the mixer (defaults to filename)
  originalFilename String
  url              String // OGG R2 CDN URL (or local /uploads/stems/ path if R2 not configured)
  mp3Url           String? // MP3 fallback for browsers without OGG support
  peaks            Json? // number[] ~1200 normalised RMS values, 0.0–1.0
  duration         Float? // Duration in seconds
  order            Int      @default(0) // Display order in the mixer
  track            Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([trackId, order])
  @@map("track_stems")
}

model Genre {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?

  // Hierarchical structure (Category > Parent > Sub-genre)
  parentId String?
  parent   Genre?  @relation("GenreHierarchy", fields: [parentId], references: [id])
  children Genre[] @relation("GenreHierarchy")

  // Relations
  profiles           ProfileGenre[]
  tracks             TrackGenre[]
  primaryForProfiles MusicianProfile[] @relation("PrimaryGenre")
  subscriptions      GenreSubscription[]
  posts              GenrePost[]
  groups             GenreGroupGenre[]

  // Head-to-Head
  h2hSamplePools H2HSamplePool[] @relation("H2HSamplePoolGenre")
  h2hMatches     H2HMatch[]      @relation("H2HMatchGenre")
  h2hRatings     H2HRating[]     @relation("H2HRatingGenre")

  @@map("genres")
}

model ProfileGenre {
  profileId String
  genreId   String

  profile MusicianProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  genre   Genre           @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([profileId, genreId])
  @@index([genreId])
  @@map("profile_genres")
}

model TrackGenre {
  trackId String
  genreId String

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([trackId, genreId])
  @@index([genreId])
  @@map("track_genres")
}

model GenreSubscription {
  id        String   @id @default(cuid())
  userId    String
  genreId   String
  createdAt DateTime @default(now())

  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@unique([userId, genreId])
  @@index([userId])
  @@index([genreId])
  @@map("genre_subscriptions")
}

model GenrePost {
  id        String  @id @default(cuid())
  genreId   String
  userId    String
  username  String
  avatarUrl String?

  type     String  @default("discussion") // "discussion" | "track"
  title    String
  body     String? @db.Text
  imageUrl String?

  trackId String? // FK to Track; set only for auto-created track posts

  upvotes      Int   @default(0)
  downvotes    Int   @default(0)
  score        Int   @default(0) // upvotes - downvotes (denormalized)
  hotScore     Float @default(0) // Reddit hot algorithm score, stored for fast ORDER BY
  commentCount Int   @default(0) // denormalized; incremented on comment creation

  flair         String?
  crossPostOfId String?
  pinned        Boolean   @default(false)
  pinnedAt      DateTime?
  hiddenAt      DateTime?
  hideReason    String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  genre       Genre           @relation(fields: [genreId], references: [id], onDelete: Cascade)
  track       Track?          @relation(fields: [trackId], references: [id], onDelete: SetNull)
  votes       GenrePostVote[]
  comments    Comment[]
  crossPostOf GenrePost?      @relation("GenrePostCrossPost", fields: [crossPostOfId], references: [id], onDelete: SetNull)
  crossPosts  GenrePost[]     @relation("GenrePostCrossPost")

  @@index([genreId, hotScore(sort: Desc)])
  @@index([genreId, createdAt(sort: Desc)])
  @@index([genreId, score(sort: Desc)])
  @@index([userId])
  @@index([trackId])
  @@index([crossPostOfId])
  @@index([pinned])
  @@map("genre_posts")
}

model GenrePostVote {
  id     String @id @default(cuid())
  userId String
  postId String
  type   String // "up" | "down"

  createdAt DateTime @default(now())

  post GenrePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("genre_post_votes")
}

model GenreGroup {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  genres    GenreGroupGenre[]

  @@index([userId])
  @@map("genre_groups")
}

model GenreGroupGenre {
  groupId String
  genreId String
  group   GenreGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  genre   Genre      @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([groupId, genreId])
  @@index([genreId])
  @@map("genre_group_genres")
}

model DiscoverySettings {
  id                  String  @id @default("singleton")
  featuredType        String  @default("track") // 'track' | 'artist' | 'playlist'
  featuredTrackId     String? // Global featured track on the discovery page
  featuredArtistId    String? // Featured artist userId
  featuredPlaylistId  String? // Featured playlist ID
  featuredLabel       String? // Custom label for the featured section
  featuredDescription String? @db.Text // Custom description shown under the hero title

  // Editor's Picks (JSON array of track IDs curated by admins)
  editorPickTrackIds Json? @default("[]")

  // Featured Producer (separate from the hero featured artist)
  featuredProducerId   String? // userId of highlighted producer
  featuredProducerNote String? @db.Text // Custom blurb about the producer

  // Featured Battle
  featuredBattleId          String? // BeatBattle ID to show on frontpage
  featuredBattleDescription String? @db.Text // Custom blurb for the battle card

  // Featured Content (card type selector — 'video' | 'news' | 'guide' | 'article')
  featuredContentType String @default("video") @map("featured_content_type")

  // Featured Tutorial / Video
  featuredTutorialUrl         String? // YouTube/video embed URL
  featuredTutorialTitle       String?
  featuredTutorialDescription String? @db.Text // Short blurb shown on the tutorial card
  featuredTutorialThumbnail   String? // Thumbnail image URL
  featuredTutorialAuthor      String? @map("featured_tutorial_author") // Name of the staff member / creator
  featuredTutorialDate        String? @map("featured_tutorial_date") // Display date string (e.g. "March 23, 2026")

  // Featured Article
  featuredArticleId String? @map("featured_article_id") // Article ID to feature on the front page

  // Trending Artist Override (admin-only, silent to public)
  trendingArtistOverrideId String? // userId of artist to pin as trending; null = auto

  // Global Brand Partners (shown on front page + battles page)
  globalSponsorIds   Json?   @default("[]") // Ordered array of BattleSponsor IDs
  globalSponsorTitle String? @default("Our Partners")

  updatedAt DateTime @updatedAt

  @@map("discovery_settings")
}

// Plugin Registry — known audio plugins with images + affiliate links
model KnownPlugin {
  id          String   @id @default(cuid())
  name        String   @unique // Primary match name (as it appears in FLP)
  aliases     Json?    @default("[]") // Additional match strings, case-insensitive
  displayName String?  // Cleaner public-facing name
  imageUrl    String?  // Logo / screenshot
  link        String?  // Affiliate / referral URL
  category    String?  // 'synth' | 'effect' | 'sampler' | 'utility' | 'other'
  developer   String?  // Plugin developer / company name
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("known_plugins")
}

// Fuji Studio - Cloud Sample Manager
model SamplePack {
  id           String  @id @default(cuid())
  guildId      String // Channel/Pack logic: Storage Guild ID
  channelId    String? @unique // Old single-channel pack logic
  forumId      String? // Tier 2: Forum ID
  threadId     String? @unique // Tier 3: Thread ID (Specific Pack)
  category     String? // Tier 1: Category Name
  name         String // Pack name (usually channel or thread name)
  description  String?
  thumbnailUrl String?
  creatorId    String? // Original uploader/owner Discord ID
  isPublic     Boolean @default(true)

  samples     SampleMetadata[]
  collections SampleCollectionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

