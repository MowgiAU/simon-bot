  channelId  String
  userId     String
  settingsId String

  // Conversation history stored as JSON array of {role, content} messages
  messages Json    @default("[]")
  topic    String? // AI-generated summary of the conversation topic
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings StudioGuideSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, userId, active])
  @@map("studio_guide_conversations")
}

model StudioGuideKnowledge {
  id       String  @id @default(cuid())
  guildId  String
  title    String // Short label (e.g. "How to sidechain in FL Studio")
  content  String // The actual knowledge / answer text
  category String  @default("general") // e.g. "fl-studio", "music-theory", "mixing"
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, enabled])
  @@map("studio_guide_knowledge")
}

model StudioGuideOptOut {
  id        String    @id @default(cuid())
  guildId   String
  userId    String
  permanent Boolean   @default(false)
  expiresAt DateTime? // null = permanent opt-out

  createdAt DateTime @default(now())

  guild    Guild                @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "studio_guide_opt_outs_guild_fkey")
  settings StudioGuideSettings? @relation(fields: [guildId], references: [guildId], map: "studio_guide_opt_outs_settings_fkey")

  @@unique([guildId, userId])
