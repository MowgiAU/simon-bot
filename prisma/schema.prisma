// ──────────────────────────────────────────────
// Auto Responder Plugin (YAGPDB-style regex commands)
// ──────────────────────────────────────────────

model ServerBoostSettings {
  id                    String   @id @default(cuid())
  guildId               String   @unique
  enabled               Boolean  @default(true)
  announcementChannelId String? // channel to post boost announcement in
  messageText           String?  @db.Text // optional plain text (supports {mention} {user} {boostCount})
  embedJson             String?  @db.Text // optional JSON-serialized embed
  reactionEmoji         String? // emoji to react to the system boost message with
  rewardRoleId          String? // role to assign when member boosts
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("server_boost_settings")
}

// Reaction Roles (Bot Messenger)
// ──────────────────────────────────────────────
model ReactionRole {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String
  emoji     String // unicode emoji or custom <name:id>
  roleId    String // Discord role ID to assign
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji])
  @@index([guildId])
  @@map("reaction_roles")
}

model AutoResponderRule {
  id                    String    @id @default(cuid())
  guildId               String
  name                  String    @default("New Rule")
  trigger               String // regex pattern or exact-match string
  triggerType           String    @default("regex") // 'regex' | 'exact' | 'startsWith' | 'contains' | 'wholeWord'
  response              String    @db.Text // response text (supports placeholders)
  embedJson             String?   @db.Text // JSON-serialized embed (optional)
  reactionEmoji         String? // emoji to react with (unicode or custom <:name:id>)
  mentionUser           Boolean   @default(false) // prepend @mention before response
  enabled               Boolean   @default(true)
  allowedChannels       String?   @db.Text // JSON array of channel IDs (null = all channels)
  ignoredChannels       String?   @db.Text // JSON array of ignored channel IDs
  cooldownSeconds       Int       @default(0)
  cooldownReactionEmoji String? // emoji to react with when rule is on cooldown
  lastTriggeredAt       DateTime?
  matchCount            Int       @default(0) // lifetime trigger count
  categoryId            String? // optional category grouping

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild    Guild                  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  category AutoResponderCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([guildId])
  @@map("auto_responder_rules")
}

model AutoResponderCategory {
  id                    String  @id @default(cuid())
  guildId               String
  name                  String  @default("New Category")
  allowedChannels       String? @db.Text // JSON array of allowed channel IDs
  ignoredChannels       String? @db.Text // JSON array of ignored channel IDs
  cooldownSeconds       Int     @default(0)
  cooldownReactionEmoji String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild               @relation(fields: [guildId], references: [id], onDelete: Cascade)
  rules AutoResponderRule[]

  @@index([guildId])
  @@map("auto_responder_categories")
}

model AutoResponderSettings {
  id                    String @id @default(cuid())
  guildId               String @unique
  globalCooldownSeconds Int    @default(0) // per-user cooldown across all rules

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("auto_responder_settings")
}

model PauseSettings {
  id             String   @id @default(cuid())
  guildId        String   @unique
  allowedRoleIds String[] @default([])

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("pause_settings")
}

// ──────────────────────────────────────────────
// Reports (user-submitted content reports)
// ──────────────────────────────────────────────
model Report {
  id             String @id @default(cuid())
  reporterUserId String // Discord user ID of person filing report
  reporterName   String // Cached display name at time of report

  // Target type: "track" | "profile" | "comment" | "message"
  targetType String
  targetId   String // ID of the reported item

  // Reported user info (owner/author of the content)
  reportedUserId String // Discord user ID of the content owner
  reportedName   String // Cached display name at time of report

  // Report details
  reason  String // Category: "spam" | "harassment" | "copyright" | "nsfw" | "scam" | "other"
  details String? @db.Text // Free-text description from reporter

  // Snapshot of content at time of report (in case it gets deleted)
  contentSnapshot String? @db.Text // JSON blob: title, body, url, etc.

  // Resolution
  status           String    @default("open") // "open" | "reviewing" | "resolved" | "dismissed"
  resolvedByUserId String? // Admin who resolved
  resolvedByName   String? // Admin display name
  resolvedAt       DateTime?
  resolutionNote   String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reporterUserId])
  @@index([reportedUserId])
  @@index([targetType, targetId])
  @@map("reports")
}

model BugReport {
  id          String  @id @default(cuid())
  userId      String  // reporter's Discord/native user ID
  username    String  // cached at submission time
  pageUrl     String
  description String  @db.Text
  errors      Json?   // last N window errors captured at submission
  userAgent   String?
  viewport    String?
  screenshotUrl String? // R2 URL of screenshot if provided

  status         String    @default("open") // "open" | "investigating" | "resolved" | "closed"
  resolvedByUserId String?
  resolvedByName   String?
  resolvedAt       DateTime?
  resolutionNote   String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
  @@map("bug_reports")
}

// ──────────────────── Articles / News Plugin ────────────────────
model Article {
  id            String  @id @default(cuid())
  guildId       String
  slug          String  @unique
  title         String
  subtitle      String?
  content       String  @db.Text // Rich HTML from WYSIWYG editor
  excerpt       String? @db.Text // Short summary for cards / previews
  coverImageUrl      String? // Hero / cover image (wide)
  squareThumbnailUrl String? // Square thumbnail for frontpage feature card

  // Author
  authorUserId String
  authorName   String
  authorAvatar String?

  // Categorisation
  category String @default("news") // news | guide | announcement | tutorial
  tags     Json?  @default("[]")

  // Publishing workflow
  status      String    @default("draft") // draft | pending | published | rejected | archived
  publishedAt DateTime?

  // Admin review
  reviewedByUserId String?
  reviewedByName   String?
  reviewedAt       DateTime?
  reviewNote       String?   @db.Text

  // Featured on front-page
  isFeatured Boolean   @default(false)
  featuredAt DateTime?

  // SEO
  metaTitle       String?
  metaDescription String? @db.Text

  // Stats
  viewCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild    Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([status, publishedAt])
  @@index([authorUserId])
  @@index([category])
  @@index([isFeatured])
  @@index([guildId])
  @@map("articles")
}

// Voice Stat Channels — auto-updating stat voice channels
model VoiceStatSettings {
