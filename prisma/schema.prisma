  boostChannelEnabled Boolean @default(false)
  boostLabel          String  @default("✨ Boosts: {count}")

  artistChannelId      String?
  artistChannelEnabled Boolean @default(false)
  artistLabel          String  @default("🎵 Artists: {count}")

  trackChannelId      String?
  trackChannelEnabled Boolean @default(false)
  trackLabel          String  @default("🎶 Tracks: {count}")

  pendingRefresh Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("voice_stat_settings")
}

// ──────────────────── SpamGuard Plugin ────────────────────

model SpamGuardSettings {
  id      String @id @default(cuid())
  guildId String @unique

  enabled Boolean @default(true)

  // Behavioral tripwire
  attachmentLimit        Int @default(3) // Max attachments in window
  attachmentWindowSec    Int @default(15) // Time window for attachment limit
  channelSpreadLimit     Int @default(3) // Max channels in window
  channelSpreadWindowSec Int @default(30) // Time window for channel spread

  // Action to take
  action         String @default("timeout") // "timeout" | "ban" | "kick" | "delete_only"
  timeoutMinutes Int    @default(10)

  // Alert channel for mod notifications
  alertChannelId String?

  // Roles exempt from spam checks
  exemptRoles String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild          Guild               @relation(fields: [guildId], references: [id], onDelete: Cascade)
  imageHashes    SpamImageHash[]
  blockedPhrases SpamBlockedPhrase[]

  @@map("spam_guard_settings")
}

model SpamBlockedPhrase {
  id            String  @id @default(cuid())
  guildId       String
  phrase        String // The phrase or full-length message to block
  description   String? // Optional label e.g. "Server nuked spam Apr 2026"
  addedByMod    String? // Discord user ID of mod who added it
  isRegex       Boolean @default(false) // If true, treat phrase as a regex pattern
  caseSensitive Boolean @default(false) // If false, match case-insensitively
  hitCount      Int     @default(0)

  createdAt DateTime @default(now())

  settings SpamGuardSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, phrase])
  @@index([guildId])
  @@map("spam_blocked_phrases")
}

model SpamImageHash {
  id          String  @id @default(cuid())
  guildId     String
  hash        String // 64-char hex perceptual hash
  description String? // Optional label e.g. "Crypto scam Jan 2026"
  addedByMod  String? // Discord user ID of mod who added it
  hitCount    Int     @default(0) // How many times this hash blocked a message

  createdAt DateTime @default(now())

  settings SpamGuardSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, hash])
  @@index([guildId])
  @@map("spam_image_hashes")
}

model AntiExternalForwardSettings {
  id      String @id @default(cuid())
  guildId String @unique

  enabled       Boolean @default(true)
  deleteMessage Boolean @default(true)
  warnUser      Boolean @default(true)

  blockInternalForwards Boolean @default(false)

  exemptRoleIds           String[] @default([])
  exemptChannelIds        String[] @default([]) // Target channels where external forwarding is allowed
  blockedSourceChannelIds String[] @default([]) // Source channels whose content can never be forwarded
  blockedTargetChannelIds String[] @default([]) // Channels where ALL forwards (internal + external) are blocked

  logChannelId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("anti_external_forward_settings")
}

// ── Track Announcer ────────────────────────────────────────────────────────────

model TrackAnnouncerSettings {
  id         String  @id @default(cuid())
  guildId    String  @unique
  enabled    Boolean @default(true)
  channelId  String? // Primary announcement channel
  channelId2 String? // Optional second channel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("track_announcer_settings")
}

/// Pending track announcement written by the API, consumed by the bot plugin.
model TrackAnnouncement {
  id              String    @id @default(cuid())
  guildId         String
  trackId         String
  trackTitle      String
  artistName      String
  profileUsername String // used to build the track URL slug
  trackSlug       String?
  coverUrl        String?
  genres          String[]  @default([])
  postedAt        DateTime?
  createdAt       DateTime  @default(now())

  @@index([postedAt])
  @@index([createdAt])
  @@map("track_announcements")
