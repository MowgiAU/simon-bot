model SpamGuardIncident {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  username    String
  triggerType String // "attachment_flood" | "channel_spread" | "known_hash"
  action      String // what was done
  channelId   String?
  messageIds  String[] @default([])
  details     String?

  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([userId])
  @@map("spam_guard_incidents")
}

// ── Enhanced Profile Styles ──────────────────────────────────────────────────
// Grants cosmetic visual styles to specific users on their public profile page.
// Admins assign these via the dashboard; they are rendered client-side only.
model ProfileStyle {
  id      String @id @default(cuid())
  guildId String
  userId  String // Discord user ID

  // Text styling (applied to display name / username)
  gradient  String? // CSS gradient, e.g. "linear-gradient(90deg,#FF6B6B,#FFD93D)"
  animation String  @default("none") // "none" | "shimmer" | "pulse" | "rainbow"

  // Avatar glow
  glowColor     String? // CSS color, e.g. "#FF6B6B"
  glowIntensity Int     @default(6) // 1–10

  // Optional badge shown next to name on profile
  badgeLabel String? // e.g. "OG Member", "Top Producer"
  badgeColor String? // CSS color for badge background

  // Admin metadata
  note      String? // internal note
  grantedBy String? // Discord user ID of granting admin
  grantedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, userId])
  @@index([userId])
  @@map("profile_styles")
}

// ──────────────────────────────────────────────
// Academy Plugin — Interactive FL Studio Learning
// ──────────────────────────────────────────────

model AcademySettings {
  id                    String  @id @default(cuid())
  guildId               String  @unique
  enabled               Boolean @default(true)
  announcementChannelId String?
  completionRoleId      String? // Role awarded when user finishes a course
  reputationReward      Int     @default(10) // Rep points per lesson completion

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("academy_settings")
}

model AcademyLesson {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String? @db.Text
  category    String  @default("basics") // basics, mixing, sound-design, arrangement, mastering
  difficulty  String  @default("beginner") // beginner, intermediate, advanced
  order       Int     @default(0) // Sort order within category
  published   Boolean @default(false)
  imageUrl    String?
  duration    Int? // Estimated minutes to complete

  // JSON lesson schema — steps, init_state, audio targets
  steps Json @default("[]")

  // Assets needed for this lesson (sample URLs, presets, etc.)
  assets Json @default("[]")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  progress AcademyProgress[]

  @@index([category, order])
  @@map("academy_lessons")
}

model AcademyProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  currentStep    Int       @default(0)
  completed      Boolean   @default(false)
  completedAt    DateTime?
  stepsCompleted Json      @default("[]") // Array of completed step indices
  score          Int       @default(0) // Points earned in this lesson

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("academy_progress")
}

// ──────────────────────────────────────────────
// Head-to-Head 1v1 Producer Battles
// ──────────────────────────────────────────────

model HeadToHeadSettings {
  id                       String   @id @default(cuid())
  guildId                  String   @unique
  enabled                  Boolean  @default(true)
  announceQueueEnabled     Boolean  @default(true)  // Post "looking for opponent" messages
  announcementChannelId    String?
  defaultProductionMinutes Int      @default(60)
  defaultVotingMinutes     Int      @default(30)
  readyUpMinutes           Int      @default(5)
  startingElo              Int      @default(1200)
  kFactor                  Int      @default(32)
  minVotesToFinalize       Int      @default(3)
  maxQueueWaitMinutes      Int      @default(30)
  samplesPerMatch          Int      @default(3)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("head_to_head_settings")
}

model H2HSamplePool {
  id          String      @id @default(cuid())
  name        String
  description String?
  genreId     String?
  genre       Genre?      @relation("H2HSamplePoolGenre", fields: [genreId], references: [id])
  isActive    Boolean     @default(true)
  samples     H2HSample[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([genreId])
  @@map("h2h_sample_pools")
}

model H2HSample {
  id         String        @id @default(cuid())
  poolId     String
  pool       H2HSamplePool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  name       String
  category   String        @default("other") // kick | snare | hat | percussion | fx | bass | melody | chords | other
  fileUrl    String        @db.Text
  fileType   String
  fileSize   Int           @default(0)
  uploadedBy String?
  createdAt  DateTime      @default(now())

  @@index([poolId])
  @@index([category])
  @@map("h2h_samples")
}

model H2HMatch {
  id      String  @id @default(cuid())
  guildId String?
  status  String  @default("queued") // queued | ready_check | melodics_vote | producing | voting | completed | forfeited | cancelled
  genreId String?
  genre   Genre?  @relation("H2HMatchGenre", fields: [genreId], references: [id])

  productionMinutes Int @default(60)
  votingMinutes     Int @default(30)

  challengerId String
  opponentId   String?

  // Per-match optional category toggles (mandatory: kick/snare/hat/percussion/fx).
  // Defaults are false now — the actual values are decided by the in-match melodics vote
  // (both players must agree per category).
  includeBass   Boolean @default(false)
  includeMelody Boolean @default(false)
  includeChords Boolean @default(false)

  // Melodics vote (each player votes yes/no per category — null = not voted yet)
  melodicsVoteDeadline    DateTime?
  challengerVoteBass      Boolean?
  challengerVoteMelody    Boolean?
  challengerVoteChords    Boolean?
  opponentVoteBass        Boolean?
  opponentVoteMelody      Boolean?
  opponentVoteChords      Boolean?

  // Sample assignment (string[] of H2HSample ids)
  sampleIds Json?

  // Ready up
  readyDeadline    DateTime?
  challengerReady  Boolean   @default(false)
  opponentReady    Boolean   @default(false)
  readyUpStartedAt DateTime?

  // Producing
  producingStartedAt DateTime?
  producingDeadline  DateTime?

  // Submissions (R2 URLs)
  challengerSubmissionUrl String?   @db.Text
  challengerSubmissionAt  DateTime?
  opponentSubmissionUrl   String?   @db.Text
  opponentSubmissionAt    DateTime?

  // Voting
  votingStart        DateTime?
  votingEnd          DateTime?
  votingAnnouncedAt  DateTime? // set once the "ready to judge" Discord announcement is posted
  winnerAnnouncedAt  DateTime? // set once the winner Discord announcement is posted
  queueAnnouncedAt   DateTime? // set once the "looking for opponent" announcement is posted

  // Outcome
  winnerId      String?
  loserId       String?
  forfeitReason String?

  // Elo deltas captured at finalization
  challengerEloBefore Int?
  challengerEloAfter  Int?
  opponentEloBefore   Int?
  opponentEloAfter    Int?

  votes H2HVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([genreId])
  @@index([challengerId])
  @@index([opponentId])
  @@map("h2h_matches")
}

model H2HVote {
  id        String   @id @default(cuid())
  matchId   String
  match     H2HMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voterId   String
  voteFor   String
  createdAt DateTime @default(now())

  @@unique([matchId, voterId])
  @@index([matchId])
  @@map("h2h_votes")
}

model H2HRating {
  id            String   @id @default(cuid())
  userId        String
  genreId       String?
  genre         Genre?   @relation("H2HRatingGenre", fields: [genreId], references: [id])
  elo           Int      @default(1200)
  wins          Int      @default(0)
  losses        Int      @default(0)
  forfeits      Int      @default(0)
  matchesPlayed Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([userId, genreId])
  @@index([genreId])
  @@index([elo])
  @@map("h2h_ratings")
}

// Configurable OG/social embed metadata per URL path
model PageEmbed {
  id          String   @id @default(cuid())
  path        String   @unique // e.g. "/" or "/battles"
  title       String
  description String   @default("")
  imageUrl    String?
  updatedAt   DateTime @updatedAt

  @@map("page_embeds")
}

model WebTicket {
  id        String   @id @default(cuid())
  userId    String   // Discord ID of the ticket opener
  status    String   @default("open") // "open" | "closed"
  subject   String
  createdAt DateTime @default(now())

  messages  WebTicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("web_tickets")
}

model WebTicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String   // Discord ID of sender (user or admin)
  content   String   @db.Text
  isAdmin   Boolean  @default(false)
  timestamp DateTime @default(now())

  ticket    WebTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("web_ticket_messages")
}

// ──────────────────────────────────────────────
// User Activity Logs (security / audit)
// ──────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?  // Internal DB user ID (null for unauthenticated)
  ip         String?
  userAgent  String?  @db.VarChar(500)
  action     String   // e.g. track.upload, comment.post, auth.login
  targetId   String?  // ID of the entity acted on
  targetType String?  // 'track' | 'comment' | 'profile' | 'battle' | etc.
  metadata   Json?    // Extra context (track title, comment snippet, etc.)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([ip])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ──────────────────────────────────────────────
// Project Versioning System (Fuji Studio Desktop Sync)
// ──────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  slug        String
  description String?  @db.Text
  arrangement  Json?   // Latest parsed FLP arrangement data
  deletedAt   DateTime?

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      ProjectVersion[]
  trackLinks    ProjectTrackLink[]
  collabProject CollabProject?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId])
  @@map("projects")
}

model ProjectVersion {
  id            String   @id @default(cuid())
  projectId     String
  versionNumber Int
  message       String?  @db.Text
  totalFiles    Int      @default(0)
  totalSize     BigInt   @default(0)
  arrangement   Json?    // FLP parsed data specific to this version
  isParsed      Boolean  @default(false)
  audioUrl      String?  // Rendered audio attachment (MP3/WAV) for playback

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileEntries ProjectFileEntry[]
  trackLinks  ProjectTrackLink[]

  createdAt DateTime @default(now())

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@map("project_versions")
}

model ProjectFileEntry {
  id          String  @id @default(cuid())
  versionId   String
  filePath    String  // Relative path within project (e.g. "Samples/kick.wav")
  fileHash    String  // SHA-256 hex, references ProjectFileBlob
  fileSize    Int
  isDirectory Boolean @default(false)

  version ProjectVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, filePath])
  @@index([fileHash])
  @@map("project_file_entries")
}

model ProjectFileBlob {
  hash       String   @id // SHA-256 hex string
  storageKey String   // R2 key: "project-blobs/{hash[0:2]}/{hash[2:]}"
  fileSize   Int
  mimeType   String?
  refCount   Int      @default(1)
  createdAt  DateTime @default(now())

  @@map("project_file_blobs")
}

model ProjectTrackLink {
  id        String   @id @default(cuid())
  projectId String
  versionId String
  trackId   String   @unique
  createdAt DateTime @default(now())

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version ProjectVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  track   Track          @relation(fields: [trackId], references: [id])

  @@index([projectId])
  @@index([trackId])
  @@map("project_track_links")
}

model DesktopToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("desktop_tokens")
}



// ── Whisper Command ──────────────────────────────────────────────────────────

model WhisperSettings {
  id             String   @id @default(cuid())
  guildId        String   @unique
  allowedRoleIds String[] @default([]) // empty = Manage Guild permission only
  updatedAt      DateTime @updatedAt

  @@map("whisper_settings")
}

model WhisperLog {
  id              String   @id @default(cuid())
  guildId         String
  channelId       String
  channelName     String
  senderId        String
  senderUsername  String
  targetId        String
  targetUsername  String
  content         String   @db.Text
  createdAt       DateTime @default(now())

  @@index([guildId, createdAt(sort: Desc)])
  @@map("whisper_logs")
}

// ── Muzzle Plugin ─────────────────────────────────────────────────────────────

model MuzzleSettings {
  id                    String   @id @default(cuid())
  guildId               String   @unique
  enabled               Boolean  @default(true)
  messageLimit          Int      @default(5)   // messages in window before muzzle
  windowSeconds         Int      @default(5)   // sliding window in seconds
  muzzleDurationMinutes Int      @default(10)  // how long to muzzle
  muzzleRoleId          String?               // role to assign
  logChannelId          String?               // optional log channel
  exemptRoleIds         String[] @default([]) // roles exempt from muzzle
  updatedAt             DateTime @updatedAt

  @@map("muzzle_settings")
}

// ── Platform Analytics ────────────────────────────────────────────────────────

model ApkDownload {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  ipHash    String
  ipRaw     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userAgent String?

  @@map("apk_downloads")
}

model UserSession {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  lastSeenAt   DateTime       @updatedAt
  endedAt      DateTime?
  durationSecs Int?
  platform     String         // "desktop" | "mobile_browser" | "android_app"
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  ipHash       String?
  ipRaw        String?
  userAgent    String?
  country      String?
  events       SessionEvent[]

  @@map("user_sessions")
}

model SessionEvent {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  sessionId String
  session   UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String      // "page_view" | "track_play" | "search" | "battle_view" | "profile_view" | "playlist_play" | "battle_submit" | "track_upload" | "download_apk"
  path      String?
  metadata  Json?

  @@map("session_events")
}

// ──────────────────────────────────────────────
// COLLABORATION SYSTEM
// ──────────────────────────────────────────────

model CollabCallout {
  id          String    @id @default(cuid())
  profileId   String
  title       String
  description String    @db.Text
  status      String    @default("open")     // "open" | "matched" | "closed"

  genreTags   String[]  @default([])          // genre slugs
  rolesWanted String[]  @default([])          // e.g. ["vocalist","mixing"]

  sampleUrl   String?
  sampleType  String?                          // "audio" | "image" | "other"

  expiresAt   DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile     MusicianProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requests    CollabRequest[]

  @@index([profileId])
  @@index([status, createdAt(sort: Desc)])
  @@map("collab_callouts")
}

model CollabRequest {
  id          String    @id @default(cuid())
  calloutId   String
  profileId   String                           // responder's MusicianProfile.id
  message     String    @db.Text
  roleOffered String?
  status      String    @default("pending")   // "pending" | "accepted" | "declined"
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  callout     CollabCallout   @relation(fields: [calloutId], references: [id], onDelete: Cascade)
  profile     MusicianProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  project     CollabProject?

  @@unique([calloutId, profileId])
  @@index([calloutId, status])
  @@index([profileId])
  @@map("collab_requests")
}

model CollabProject {
  id                    String    @id @default(cuid())
  requestId             String    @unique
  initiatorProfileId    String
  collaboratorProfileId String
  status                String    @default("active") // "active" | "releasing" | "released" | "abandoned"

  // Optional desktop project link
  projectId             String?   @unique

  // Set on release
  trackId               String?   @unique

  // Joint approval flags
  initiatorApproved     Boolean   @default(false)
  collaboratorApproved  Boolean   @default(false)

  // Workspace conversation (reuses existing messaging system)
  conversationId        String?   @unique

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  request      CollabRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  initiator    MusicianProfile @relation("CollabProjectInitiator", fields: [initiatorProfileId], references: [id], onDelete: Cascade)
  collaborator MusicianProfile @relation("CollabProjectCollaborator", fields: [collaboratorProfileId], references: [id], onDelete: Cascade)
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  track        Track?          @relation(fields: [trackId], references: [id], onDelete: SetNull)
  conversation Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  files        CollabFile[]
  updates      CollabUpdate[]

  @@index([initiatorProfileId])
  @@index([collaboratorProfileId])
  @@index([status])
  @@map("collab_projects")
}

model CollabFile {
  id         String    @id @default(cuid())
  projectId  String
  uploaderId String                           // MusicianProfile.id
  label      String
  url        String
  mimeType   String?
  sizeBytes  Int       @default(0)
  fileType   String    @default("other")      // "audio" | "project" | "image" | "other"
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  project    CollabProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("collab_files")
}

model CollabUpdate {
  id        String   @id @default(cuid())
  projectId String
  authorId  String                            // MusicianProfile.id
  content   String   @db.Text
  kind      String   @default("update")       // "message" | "update"
  createdAt DateTime @default(now())

  project   CollabProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("collab_updates")
}
