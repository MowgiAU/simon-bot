  sampleId String         @unique
  sample   SampleMetadata @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  filename String
  url      String
  filesize Int
  mimetype String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fuji_project_files")
}

// ── Beat Market (Investment System) ──────────────────────────────────────────


model SlotMachineSettings {
